{%- if settings.background_media == 'image' and settings.background_image != blank -%}
  {%- assign img_style = 'object-fit: ' | append: settings.background_image_position -%}
  <div class="bg-image">
    {{ settings.background_image | image_url: width: 1920 | image_tag:
      class: 'bg-image__media',
      loading: 'lazy',
      style: img_style
    }}
  </div>
{%- endif -%}

{%- if settings.background_media == 'video' and settings.video != blank -%}
  {%- assign video_style = 'object-fit: ' | append: settings.video_position -%}
  <div class="bg-video">
    {{ settings.video | video_tag:
      autoplay: true,
      loop: true,
      muted: true,
      class: 'bg-video__media',
      style: video_style
    }}
  </div>
{%- endif -%}

{%- if settings.toggle_overlay -%}
  {%- if settings.overlay_style == 'gradient' -%}
    <div class="bg-overlay" style="background: linear-gradient({{ settings.gradient_direction }}, {{ settings.overlay_color }}, transparent);"></div>
  {%- else -%}
    <div class="bg-overlay" style="background: {{ settings.overlay_color }};"></div>
  {%- endif -%}
{%- endif -%}

{% stylesheet %}
  .bg-image,
  .bg-video {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .bg-image__media,
  .bg-video__media {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
{% endstylesheet %}
