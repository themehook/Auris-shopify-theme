<!-- Mobile Menu Bar -->
<div class="col-auto d-none d-md-only-block">
  <div class="mobile__menu_bar header__actions_btn--menu">
    {% render 'hooktheme-icon-hamburger' %}
  </div>
</div>
<!-- Mobile Menu Bar end -->

<!-- Header Menu Start -->
<nav class="header__menu {{ menu_alignment }}  col-lg-5 d-md-none">
  {%- render 'menu-nav', container: container -%}
</nav>
<!-- Header Menu End -->

<!-- Header Logo Start -->
<div class="header__logo text-center col-lg-2">
  {%- if request.page_type == 'index' -%}
    <h1 class="header__heading mb-0">
  {%- endif -%}
  {%- render 'header-logo', className: 'header__logo_link' -%}
  {%- if request.page_type == 'index' -%}
    </h1>
  {%- endif -%}
</div>
<!-- Header Logo End -->

<!-- Header Actions Start -->
<div class="header__actions {% if action_button_border %}action_button_border{% endif %} col-lg-5">
  {%- unless search_button == 'hide' -%}
    <button
      class="header__actions_btn header__actions_btn--search d-none"
      aria-label="{{ 'general.search.search' | t }}"
    >
      {% render 'hooktheme-icon-search' %}
    </button>
  {%- endunless -%}

  {%- if shop.customer_accounts_enabled and account_icon -%}
    <a
      href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
      class="header__actions_btn header__actions_btn--user d-md-none"
    >
      {%- if customer -%}
        {% render 'hooktheme-icon-account' %}
      {%- else -%}
        {% render 'user-icon' %}
      {%- endif -%}
      <span class="visually-hidden">
        {%- liquid
          if customer
            echo 'customer.account_fallback' | t
          else
            echo 'customer.log_in' | t
          endif
        -%}
      </span>
    </a>
  {%- endif -%}

  {%- if compare_icon -%}
    <a href="/pages/compare" class="header__actions_btn header__actions_btn--wishlist d-md-none">
      {% render 'compare-icon' %}
      <span class="header__actions_btn_cart_num compare__count"></span>
    </a>
  {%- endif -%}

  {%- if wishlist_icon -%}
    <a href="/pages/wishlist" class="header__actions_btn header__actions_btn--wishlist d-md-none">
      {% render 'heart-icon' %}
      {% if settings.show_all_wishlist %}
        <span class="header__actions_btn_cart_num wishlist__count"></span>
      {% endif %}
    </a>
  {%- endif -%}

  {%- if cart_icon -%}
    {%- unless template contains 'cart' -%}
      {%- if settings.cart_type == 'drawer' -%}
        <open-minicart>
          <a href="{{ routes.cart_url }}" class="header__actions_btn header__actions_btn--cart">
            {% render 'hooktheme-icon-cart', icon: cart_icon_type %}

            <div class="cart-count-bubble header__actions_btn_cart_num">
              {%- if cart.item_count < 100 -%}
                <span id="cart-notification-count" aria-hidden="true">{{ cart.item_count }}</span>
              {%- endif -%}
              <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
            </div>
          </a>
        </open-minicart>
      {%- else -%}
        <a href="{{ routes.cart_url }}" class="header__actions_btn header__actions_btn--cart">
          {% render 'hooktheme-icon-cart', icon: cart_icon_type %}
          <div class="cart-count-bubble header__actions_btn_cart_num">
            {%- if cart.item_count < 100 -%}
              <span id="cart-notification-count" aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
            <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
          </div>
        </a>
      {%- endif -%}
    {%- endunless -%}
  {%- endif -%}
  {% if section.settings.quick_action_button %}
    <div class="header--button-module d-md-none">
      <a href="{{ section.settings.quick_action_button_link }}" class="button button--parimary button--small">
        {{ section.settings.quick_action_button_label }}
      </a>
    </div>
  {% endif %}
</div>
