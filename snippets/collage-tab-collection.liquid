{% liquid
  assign collection_media = false
  if collection.featured_image != blank or custom_image != blank
    assign collection_media = true
  endif
%}
<div
  class="single-tab--collage-media tab--collage-media-{{ section.settings.height }} {% if collection.featured_image != blank or custom_image != blank %}media{% else %} placeholder {% endif %}"

  {% if section.settings.height == 'adapt' and collection_media %}
    style="padding-top: {% if custom_image != blank %} {{ 1 | divided_by: custom_image.aspect_ratio | times: 100 }}%; {% else %}{{ 1 | divided_by: collection.featured_image.aspect_ratio | times: 100 }}%;{% endif %}"
  {% endif %}
>
  {%- if collection.featured_image != blank or custom_image != blank -%}
    {% if custom_image != blank %}
      {%- capture sizes -%} (min-width: 768px) {% if columns > 1 %}calc((100vw - 10rem) / 2){% else %}calc(100vw - 10rem){% endif %}, calc(100vw - 3rem) {%- endcapture -%}
      {% liquid
        assign height = custom_image.width | divided_by: custom_image.aspect_ratio | round
      %}
      {{
        custom_image
        | image_url: width: 1500
        | image_tag:
          loading: 'lazy',
          height: height,
          sizes: sizes,
          widths: '165, 360, 750, 1000, 1500, 1780, 2000, 3000, 3840'
      }}
    {% else %}
      <img
        srcset="
          {%- if collection.featured_image.width >= 165 -%}{{ collection.featured_image | image_url: width: 165 }} 165w,{%- endif -%}
          {%- if collection.featured_image.width >= 330 -%}{{ collection.featured_image | image_url: width: 330 }} 330w,{%- endif -%}
          {%- if collection.featured_image.width >= 535 -%}{{ collection.featured_image | image_url: width: 535 }} 535w,{%- endif -%}
          {%- if collection.featured_image.width >= 750 -%}{{ collection.featured_image | image_url: width: 750 }} 750w,{%- endif -%}
          {%- if collection.featured_image.width >= 1000 -%}{{ collection.featured_image | image_url: width: 1000 }} 1000w,{%- endif -%}
          {%- if collection.featured_image.width >= 1500 -%}{{ collection.featured_image | image_url: width: 1500 }} 1500w,{%- endif -%}
          {%- if collection.featured_image.width >= 3000 -%}{{ collection.featured_image | image_url: width: 3000 }} 3000w,{%- endif -%}
          {{ collection.featured_image | image_url }} {{ collection.featured_image.width }}w
        "
        src="{{ collection.featured_image | image_url: width: 1500 }}"
        sizes="(min-width: {{ settings.container_lg_width }}px) {{ settings.container_lg_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 10rem) / 2), calc(100vw - 3rem)"
        alt="{{ collection.title | escape }}"
        height="{{ collection.featured_image.height }}"
        width="{{ collection.featured_image.width }}"
        loading="lazy"
        class="motion-reduce"
      >
    {% endif %}
  {%- else -%}
    {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg-new' }}
  {%- endif -%}
</div>
