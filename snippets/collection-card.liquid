{%- unless sizes -%}
  {%- capture sizes -%}(min-width: {{ settings.container_lg_width }}px) {{ settings.container_lg_width | minus: 100 | divided_by: 3 }}px, (min-width: 750px) calc((100vw - 130px) / 3), calc(100vw - 30px){%- endcapture -%}
{%- endunless -%}
<a
  {% if collection.all_products_count > 0 %}
    href="{{ collection.url }}"
  {% endif %}
  class="{% if image != blank %} card--media{% else %}{% if media_aspect_ratio != 'adapt' %} card--stretch{% endif %}{% endif %} collection__card {% if content_on_container %}collection-card-content-on-container{% endif %} collection--list-card-padded-{{ section.settings.card_padding_type }}"
>
  {%- if image != blank -%}
    <div class="collection-card--media__wrapper {{ image_width }} {% unless image_as_icon %}card--client-height{% endunless %}">
      <div
        class="{% if image_as_icon %}collection--list-media-img--icon {% else %} media media--{{ media_aspect_ratio }}{% endif %} {% if transparent_media %}media--transparent{% endif %} media--hover-effect overflow-hidden"
        {% if media_aspect_ratio == 'adapt' %}
          style="padding-bottom: {{ 1 | divided_by: image.aspect_ratio | times: 100 }}%;"
        {% endif %}
      >
        {% liquid
          assign height = image.width | divided_by: image.aspect_ratio | round
        %}
        {{
          image
          | image_url: width: 1500
          | image_tag: loading: 'lazy', height: height, sizes: sizes, widths: '165, 360, 750, 1000, 1500'
        }}
      </div>
    </div>
  {%- else -%}
    {%- if collection.featured_image != blank -%}
      <div class="collection-card--media__wrapper {{ image_width }} {% unless image_as_icon %}card--client-height{% endunless %}">
        <div
          class="{% if image_as_icon %}collection--list-media-img--icon {% else %} media media--{{ media_aspect_ratio }}{% endif %} media--hover-effect overflow-hidden"

          {% if media_aspect_ratio == 'adapt' %}
            style="padding-bottom: {{ 1 | divided_by: collection.featured_image.aspect_ratio | times: 100 }}%;"
          {% endif %}
        >
          <img
            srcset="
              {%- if collection.featured_image.width >= 165 -%}{{ collection.featured_image | image_url: width: 165 }} 165w,{%- endif -%}
              {%- if collection.featured_image.width >= 330 -%}{{ collection.featured_image | image_url: width: 330 }} 330w,{%- endif -%}
              {%- if collection.featured_image.width >= 535 -%}{{ collection.featured_image | image_url: width: 535 }} 535w,{%- endif -%}
              {%- if collection.featured_image.width >= 750 -%}{{ collection.featured_image | image_url: width: 750 }} 750w,{%- endif -%}
              {%- if collection.featured_image.width >= 1000 -%}{{ collection.featured_image | image_url: width: 1000 }} 1000w,{%- endif -%}
              {%- if collection.featured_image.width >= 1500 -%}{{ collection.featured_image | image_url: width: 1500 }} 1500w,{%- endif -%}
              {%- if collection.featured_image.width >= 3000 -%}{{ collection.featured_image | image_url: width: 3000 }} 3000w,{%- endif -%}
              {{ collection.featured_image | image_url }} {{ collection.featured_image.width }}w
            "
            src="{{ collection.featured_image | image_url: width: 1500 }}"
            sizes="{{ sizes }}"
            alt=""
            height="{{ collection.featured_image.height }}"
            width="{{ collection.featured_image.width }}"
            loading="lazy"
            class="motion-reduce"
          >
        </div>
      </div>
    {%- else -%}
      <div
        class="placeholder_svg_parent collection--list-svg {% if image_as_icon %}collection-card--svg-icon{% endif %} media--{{ media_aspect_ratio }} {% unless image_as_icon %}card--client-height{% endunless %}"
        {% if media_aspect_ratio == 'adapt' %}
          style="padding-bottom: 100%"
        {% endif %}
      >
        {% capture current_placeholder_index %}{% cycle 1, 2, 3, 4, 5 %}{% endcapture %}
        {{ 'collection-apparel-' | append: current_placeholder_index | placeholder_svg_tag: 'placeholder-svg-new' }}
      </div>
    {%- endif -%}
  {%- endif -%}
  <div
    class="
      product__categories--content  {% if show_icon %} d-flex justify-content-between align-items-center {% endif %}
      {% unless section.settings.show_icon %} text-{{ section.settings.card_alignment }} {% endunless %}
    "
  >
    <div class="product__categories--content__left">
      {%- if show_product_items and product_items_position == 'above' -%}
        {%- if product_items_style == 'badge' -%}
          <span class="product__categories--content__subtitle product__categories--subtitle--badge">
            {{- collection.products_count }} {{ 'sections.collection_list.items' | t -}}
          </span>
        {%- else -%}
          <span class="product__categories--content__subtitle">
            {{- collection.products_count }} {{ 'sections.collection_list.items' | t -}}
          </span>
        {%- endif -%}
      {%- endif -%}
      {%- if collection != blank -%}
        <h3 class="collection-card--title {{ title_size | default: 'h5' }} mb-0">{{ collection.title }}</h3>
      {%- else -%}
        <h3 class="collection-card--title {{ title_size | default: 'h5' }} mb-0">
          {{ 'sections.collection_list.default_title' | t }}
        </h3>
      {%- endif -%}
      {%- if show_product_items and product_items_position != 'above' -%}
        {%- if product_items_style == 'badge' -%}
          <span class="product__categories--content__subtitle product__categories--subtitle--badge">
            {{- collection.products_count }} {{ 'sections.collection_list.items' | t -}}
          </span>
        {%- else -%}
          <span class="product__categories--content__subtitle">
            {{- collection.products_count }} {{ 'sections.collection_list.items' | t -}}
          </span>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if show_icon -%}
      <div class="product__categories--icon">
        <span class="product__categories--icon__link">
          {% render 'hooktheme-icon-arrow-right' %}
        </span>
      </div>
    {%- endif -%}
  </div>
</a>
