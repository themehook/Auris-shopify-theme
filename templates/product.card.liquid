{% comment %}
  Product recommendation slider
{% endcomment %}
{%- layout none -%}
{%- render 'product-card',
  className: 'swiper-slide',
  product_card_product: product,
  media_size: settings.recent_viewed_image_ratio,
  show_secondary_image: settings.recent_viewed_show_secondary_image,
  show_vendor: settings.recent_viewed_show_vendor,
  show_badge: settings.recent_viewed_show_badges,
  show_cart_button: settings.recent_viewed_show_cart_button,
  show_preorder_button: settings.recent_viewed_show_preorder_button,
  show_quick_view: settings.recent_viewed_show_quick_view_button,
  show_quick_compare: settings.recent_viewed_show_compare_view_button,
  show_wishlist: settings.recent_viewed_show_wishlist_button,
  show_countdown: settings.recent_viewed_show_countdown,
  show_title: settings.recent_viewed_show_title,
  show_price: settings.recent_viewed_show_price,
  show_rating: settings.recent_viewed_show_product_rating,
  card_style: settings.recent_viewed_card_style,
  color_swatches: settings.recent_viewed_color_swatches,
  color_scheme: settings.recent_viewed_product_card_color_scheme,
  spacing: settings.recent_viewed_product_card_spacing,
  corner_radius: settings.recent_viewed_product_card_radius,
  show_border: settings.recent_viewed_show_border,
  cart_button_type: settings.recent_viewed_cart_button_type,
  action_buttons_position: settings.recent_viewed_action_buttons_position,
  action_buttons_style: settings.recent_viewed_action_button_style,
  show_always: settings.recent_viewed_show_always,
  low_stock_value: settings.recent_viewed_low_stock_value,
  minimum_amount_value: settings.recent_viewed_minimum_amount_value,
  show_inventory_quantity: settings.recent_viewed_show_inventory_quantity,
  show_inventory_status: settings.recent_viewed_show_inventory_status,
  in_stock_color: settings.recent_viewed_in_stock,
  out_of_stock_color: settings.recent_viewed_out_of_stock,
  low_stock_color: settings.recent_viewed_low_stock,
  continue_selling_color: settings.recent_viewed_continue_selling
-%}
