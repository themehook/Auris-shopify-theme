{{ 'section-separator.css' | asset_url | stylesheet_tag }}

<div class="separator section-{{ section.id }}-padding">
  <div class="{% if section.settings.enable_full_width %}container-fluid p-0{% else %}container{% endif %}">
    {% if section.settings.heading != blank %}
      <h2 class="separator__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.show_separator_line %}
      <hr
        class="separator__line "
        style="background-color: {{ section.settings.separator_color }};"
      >
    {% endif %}
  </div>
</div>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.distance_from_top }}px;
    padding-bottom: {{ section.settings.distance_from_bottom }}px;
  }

  .section-{{ section.id }}-padding .separator__line {
    height: 1px;
    border: none;
  }
{% endstyle %}

{% schema %}
{
  "name": "Separator",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "checkbox",
      "id": "show_separator_line",
      "label": "Show separator line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_full_width",
      "label": "Enable full width line",
      "default": false
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#AE8E8E"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "distance_from_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Distance from the top",
      "default": 52
    },
    {
      "type": "range",
      "id": "distance_from_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Distance from the bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Separator",
      "category": "Basic"
    }
  ]
}
{% endschema %}
