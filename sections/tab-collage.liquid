        {
          "value": "container",
          "label": "Boxed"
        },
        {
          "value": "container-fluid",
          "label": "Full width"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_offset",
      "label": "Enable horizontal space",
      "default": true,
      "info": "It will work if you select the \"Full width\" of the page width"
    },
    {
      "type": "checkbox",
      "id": "snow_fall",
      "label": "Enable snow fall",
      "default": false
    },
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
