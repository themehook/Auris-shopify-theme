          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "select",
          "id": "item_title_size",
          "options": [
            {
              "value": "h5",
              "label": "Heading 5"
            },
            {
              "value": "h4",
              "label": "Heading 4"
            },
            {
              "value": "h3",
              "label": "Heading 3"
            },
            {
              "value": "h2",
              "label": "Heading 2"
            }
          ],
          "default": "h3",
          "label": "Heading size"
        },
        {
