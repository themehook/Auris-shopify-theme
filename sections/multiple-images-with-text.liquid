{%- liquid
  assign is_rtl_theme = false
  if settings.use_rtl and settings.rtl_languages == blank
    assign is_rtl_theme = true
  endif

  if settings.use_rtl and settings.rtl_languages != blank
    assign rtl_langs = settings.rtl_languages | split: ','
    for lang in rtl_langs
      if lang == request.locale.iso_code
        assign is_rtl_theme = true
      endif
    endfor
  endif

  assign desktop_column = section.settings.media_desktop_column
  case desktop_column
    when 'small'
      assign flex_grow_on_image = '0'
      assign flex_grow_on_content = '1'
    when 'medium'
      assign flex_grow_on_image = '1'
      assign flex_grow_on_content = '1'
    else
      assign flex_grow_on_image = '1'
      assign flex_grow_on_content = '0'
  endcase

  assign image_content_position_on_desktop_attribute = section.settings.content_position_on_desktop

  case image_content_position_on_desktop_attribute
    when 'top'
      assign image_content_position_on_desktop_attribute_assign = 'justify-content-start'
    when 'bottom'
      assign image_content_position_on_desktop_attribute_assign = 'justify-content-end'
    else
      assign image_content_position_on_desktop_attribute_assign = 'justify-content-center'
  endcase

  assign image_content_alignment_on_desktop = section.settings.content_alignment_on_desktop

  case image_content_alignment_on_desktop
    when 'right'
      assign image_content_alignment_on_desktop_attribute = 'align-items-end'
    when 'center'
      assign image_content_alignment_on_desktop_attribute = 'align-items-center'
    else
      assign image_content_alignment_on_desktop_attribute = 'align-items-start'
  endcase

  assign image_content_alignment_on_mobile = section.settings.mobile_content_alignment

  case image_content_alignment_on_mobile
    when 'left'
      assign image_content_alignment_on_mobile_atrribute = 'alignment--text-left-mobile'
    when 'center'
      assign image_content_alignment_on_mobile_atrribute = 'alignment--text-center-mobile'
    else
      assign image_content_alignment_on_mobile_atrribute = 'alignment--text-right-mobile'
  endcase

  if section.settings.full_width
    assign column_class = 'col-12'
  else
    assign column_class = 'col-md-4'
  endif

  case section.settings.container
    when 'container'
      assign container = 'container'
    when 'container-fluid'
      assign container = 'container-fluid'
    else
      assign container = 'container-fluid px-0'
  endcase

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

{{ 'hooktheme-image-with-text.css' | asset_url | stylesheet_tag }}
{{ 'section-multiple-images-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
   .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #MainContent > :first-child .section--top-space-{{ section.id }} {
    margin-top: calc(var(--header-height) * var(--transparent-header-show));
  }
{%- endstyle -%}

{% if is_rtl_theme %}
  {{ 'hooktheme-image-with-text-rtl.css' | asset_url | stylesheet_tag }}
{% endif %}

<div class="multiple--images-with-text section-{{ section.id }}-padding section--top-space-{{ section.id }}">
  <div class="{{ container }}">
    <div class="image-with-text__grid {% if section.settings.layout == "text_first" %}desktop-row-reverse {% endif %} d-flex flex-wrap color-{{ section.settings.color_scheme }} gradient {% if section.settings.round_corner %} rounded--image {% endif %} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="{{ column_class }} flex-grow-{{ flex_grow_on_image }} multiple--images-media-grid-item">
        <div class="multiple-images-with--text-media multiple--images-media-wrapper {% if section.settings.layout == "image_first" %}images--with-text-left-media{% endif %}">
          <div class="multiple--images-column">
            {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
            {%- capture sizes -%}
                    (min-width: {{ settings.container_lg_width }}px) {{ settings.container_lg_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), 100vw
                  {%- endcapture -%}
            <div class="multiple--images-column-list">
              <div
                class="multiple--image-media aspect-media--{{ section.settings.image_ratio }} {% if section.settings.image != blank %}media{% else %}placeholder{% endif %} {% if section.settings.round_corner %} rounded--image {% endif %}"
                {% if section.settings.image_ratio == 'adapt' and section.settings.image != blank %}
                  style="padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                {%- if section.settings.image != blank -%}
                  {{
                    section.settings.image
                    | image_url: width: 1500
                    | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                  }}
                {%- else -%}
                  {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg-new' }}
                {%- endif -%}
              </div>
            </div>
            <div class="multiple--images-column-list">
              <div
                class="multiple--image-media aspect-media--{{ section.settings.image_ratio }} {% if section.settings.image_2 != blank %}media{% else %}placeholder{% endif %} {% if section.settings.round_corner%} rounded--image {% endif %} "
                {% if section.settings.image_ratio == 'adapt' and section.settings.image_2 != blank %}
                  style="padding-bottom: {{ 1 | divided_by: section.settings.image_2.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                {%- if section.settings.image_2 != blank -%}
                  {{
                    section.settings.image_2
                    | image_url: width: 1500
                    | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                  }}
                {%- else -%}
                  {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg-new' }}
                {%- endif -%}
              </div>
            </div>
            <div class="multiple--images-column-list">
              <div
                class="multiple--image-media aspect-media--{{ section.settings.image_ratio }} {% if section.settings.image_3 != blank %}media{% else %}placeholder{% endif %} {% if section.settings.round_corner%} rounded--image {% endif %}"
                {% if section.settings.image_ratio == 'adapt' and section.settings.image_3 != blank %}
                  style="padding-bottom: {{ 1 | divided_by: section.settings.image_3.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                {%- if section.settings.image_3 != blank -%}
                  {{
                    section.settings.image_3
                    | image_url: width: 1500
                    | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                  }}
                {%- else -%}
                  {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg-new' }}
                {%- endif -%}
              </div>
            </div>
            <div class="multiple--images-column-list">
              <div
                class="multiple--image-media aspect-media--{{ section.settings.image_ratio }} {% if section.settings.image_4 != blank %}media{% else %}placeholder{% endif %} {% if section.settings.round_corner%} rounded--image {% endif %}"
                {% if section.settings.image_ratio == 'adapt' and section.settings.image_4 != blank %}
                  style="padding-bottom: {{ 1 | divided_by: section.settings.image_4.aspect_ratio | times: 100 }}%;"
                {% endif %}
              >
                {%- if section.settings.image_4 != blank -%}
                  {{
                    section.settings.image_4
                    | image_url: width: 1500
                    | image_tag: sizes: sizes, widths: widths, fetchpriority: fetch_priority
                  }}
                {%- else -%}
                  {{ 'product-apparel-4' | placeholder_svg_tag: 'placeholder-svg-new' }}
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="{{ column_class }}  flex-grow-{{ flex_grow_on_content }} image-with-text__text-item">
        <div class="image-with--text-content {% if section.settings.content_padding != "none" %} image-with-text-padding-{{ section.settings.content_padding }}{% else %} {% if section.settings.layout == "text_first" and section.settings.media_desktop_column != "large" %}image-with-text-padding--left-false{% endif %}{% endif %} {{ image_content_position_on_desktop_attribute_assign }} {{ image_content_alignment_on_desktop_attribute }} text-{{ section.settings.content_alignment_on_desktop }}  {{ image_content_alignment_on_mobile_atrribute }}">
          {%- for block in section.blocks -%}
            {% case block.type %}
              {%- when 'heading' -%}
                <h2
                  class="image-with--text-heading {{ block.settings.heading_size }} mb-0 {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                  {{ block.shopify_attributes }}
                >
                  {{-
                    block.settings.heading
                    | replace: 'p>', 'span>'
                    | replace: 'h1>', 'span>'
                    | replace: 'h2>', 'span>'
                    | replace: 'h3>', 'span>'
                    | replace: 'h4>', 'span>'
                    | replace: 'h5>', 'span>'
                    | replace: 'h6>', 'span>'
                  -}}
                </h2>
              {%- when 'caption' -%}
                <p
                  class="image-with-text__text image-with-text__text--caption {{ block.settings.text_style }} {{ block.settings.text_style }}--{{ block.settings.text_size }} {{ block.settings.text_style }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.caption | escape }}
                </p>
              {%- when 'text' -%}
                <div
                  class="image-with-text__text rte {{ block.settings.text_style }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.text }}
                </div>
              {%- when 'button' -%}
                {% liquid
                  assign button_class = ''
                  case block.settings.button_style
                    when 'primary'
                      assign button_class = 'button button--primary'
                    when 'secondary'
                      assign button_class = 'button button--secondary'
                    when 'icon'
                      assign button_class = 'link with--icon'
                    else
                      assign button_class = 'link'
                  endcase
                %}

                {% if block.settings.button_label != blank %}
                  <div
                    class="button__wrapper {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                    {% if settings.animations_reveal_on_scroll %}
                      data-cascade
                      style="--animation-order: {{ forloop.index }};"
                    {% endif %}
                    {{ block.shopify_attributes }}
                  >
                    <a
                      {% if block.settings.button_link == blank %}
                        role="link" aria-disabled="true"
                      {% else %}
                        href="{{ block.settings.button_link }}"
                      {% endif %}
                      class="{{ button_class }} {% unless block.settings.button_type == 'icon' %}button--{{ block.settings.button_size }}{% endunless %} {% if block.settings.button_icon %} button--with-icon{% endif %}"
                    >
                      {{- block.settings.button_label | escape }}
                      {% if block.settings.button_icon %}
                        <span class="button--icon button--icon-right">{% render 'hooktheme-icon-chevron-right' %}</span>
                      {% endif %}
                    </a>
                  </div>
                {% endif %}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
