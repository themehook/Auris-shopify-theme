          "type": "media_item"
        },
        {
          "type": "text_item"
        },
        {
          "type": "media_item"
        },
        {
          "type": "text_item"
        },
        {
          "type": "media_item"
        },
        {
          "type": "text_item"
        }
      ]
    }
