<link rel="stylesheet" href="{{ 'hooktheme-rte.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'hooktheme-rte.css' | asset_url | stylesheet_tag }}</noscript>

{{ 'promo-banner.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-rating.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .rating {
    display: inline-block;
    margin: 0;
  }
  .promo--banner-product-card .rating-star {
    --letter-spacing: 0.7;
    --font-size: 2;
  }
      .section-{{ section.id }}-padding {
       padding-top: {{ section.settings.mobile_padding_top }}px;
       padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
        --padding-top: {{ section.settings.mobile_padding_top }}px;
     }
     @media screen and (min-width: 750px) {
       .section-{{ section.id }}-padding {
         padding-top: {{ section.settings.padding_top }}px;
         padding-bottom: {{ section.settings.padding_bottom }}px;
         --padding-top: {{ section.settings.padding_top }}px;
       }
     }
     #MainContent > :first-child .section--top-space-{{ section.id }} {
       padding-top: calc(var(--header-height) * var(--transparent-header-show) + var(--padding-top));
     }
     @media screen and (max-width: 749px){
        .promo--banner__media.media-height-on-mobile{
          height: {{ section.settings.auto_best_fit_height_mobile }}px;
        }
     }
{%- endstyle -%}

{% liquid
  assign container = ''
  assign page_offset = false
  if section.settings.container == 'container'
    assign container = 'container'
  elsif section.settings.container == 'container-fluid'
    assign container = 'container-fluid'
    unless section.settings.show_offset
      assign page_offset = true
    endunless
  else
    assign container = 'container-fluid px-0'
  endif

  if section.settings.border_type == 'solid'
    assign border_class = 'promo--banner-border'
    assign border_class_mobile = 'promo--banner-border-mobile'
  elsif section.settings.border_type == 'outline'
    assign border_class = 'promo--banner-border-outline'
    assign border_class_mobile = 'promo--banner-border-outline-mobile'
  endif
%}
{% capture promo_card_attribute %}
{% if section.settings.desktop_space_on_promo_card %}promo--card-space-desktop{% endif %} {% if section.settings.mobile_space_on_promo_card %}promo--card-space-mobile{% endif %}
{% endcapture %}
<div class="promo--banner-wrapper section--top-space-{{ section.id }} section-{{ section.id }}-padding">
  <div class="{{ container }} {% if page_offset %}p-0{% endif %}">
    <div class="promo--banner--container relative">
      {%- if section.settings.image_2 != blank and section.settings.show_image_bg -%}
        <div class="promo--banner__media media media-height-{{ section.settings.bg_desktop_height }} {% if section.settings.custom_mobile_height %} media-height-on-mobile {% endif %} {% if section.settings.round_corner %} rounded--box{% endif %}"
          {% if section.settings.bg_desktop_height == 'adapt' %}
            style="padding-bottom: {{ 1 | divided_by: section.settings.image_2.aspect_ratio | times: 100 }}%;"
          {% endif %}
        >
          <img
            srcset="
              {%- if section.settings.image_2.width >= 375 -%}{{ section.settings.image_2 | image_url: width: 375 }} 375w,{%- endif -%}
              {%- if section.settings.image_2.width >= 550 -%}{{ section.settings.image_2 | image_url: width: 550 }} 550w,{%- endif -%}
              {%- if section.settings.image_2.width >= 750 -%}{{ section.settings.image_2 | image_url: width: 750 }} 750w,{%- endif -%}
              {%- if section.settings.image_2.width >= 1100 -%}{{ section.settings.image_2 | image_url: width: 1100 }} 1100w,{%- endif -%}
              {%- if section.settings.image_2.width >= 1500 -%}{{ section.settings.image_2 | image_url: width: 1500 }} 1500w,{%- endif -%}
              {%- if section.settings.image_2.width >= 1780 -%}{{ section.settings.image_2 | image_url: width: 1780 }} 1780w,{%- endif -%}
              {%- if section.settings.image_2.width >= 2000 -%}{{ section.settings.image_2 | image_url: width: 2000 }} 2000w,{%- endif -%}
              {%- if section.settings.image_2.width >= 3000 -%}{{ section.settings.image_2 | image_url: width: 3000 }} 3000w,{%- endif -%}
              {%- if section.settings.image_2.width >= 3840 -%}{{ section.settings.image_2 | image_url: width: 3840 }} 3840w,{%- endif -%}
              {{ section.settings.image_2 | image_url }} {{ section.settings.image_2.width }}w
            "
            sizes="100vw"
            src="{{ section.settings.image_2 | image_url: width: 1500 }}"
            loading="lazy"
            alt="{{ section.settings.image_2.alt | escape }}"
            width="{{ section.settings.image_2.width }}"
            height="{{ section.settings.image_2.width | divided_by: section.settings.image_2.aspect_ratio }}"
          >
        </div>
      {%- endif -%}
      <div class="promo--banner-inner {% if section.settings.image_2 != blank and section.settings.show_image_bg %}  promo-banner-position {% endif %} {% if section.settings.border %}{{ border_class }}{% endif %} {% if section.settings.border_mobile %}{{ border_class_mobile }}{% endif %} {% if section.blocks.size == 1 %} not-promo--banner-grid{% endif %} color-{{ section.settings.color_scheme }} gradient {% if section.settings.round_corner %} rounded--box{% endif %} {{ promo_card_attribute }}">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'text' %}
              <!-- Promo Banner Content -->
              <div
                class="promo--banner-content promo--banner-text-padding-{{ block.settings.card_padding_type }} promo--banner-content-{{ block.settings.content_alignment }}"
                {{ block.shopify_attributes }}
              >
                <div class="promo--banner-content--subheading">{{ block.settings.subheading }}</div>
                <h2 class="promo--banner-content--heading {{ block.settings.heading_size }} mb-0">
                  {{ block.settings.heading }}
                </h2>
                <div class="promo--banner-content-text rte ">
                  {{ block.settings.text }}
                </div>

                {% liquid
                  case block.settings.button_type
                    when 'primary'
                      assign button_class = 'button button--primary'
                    when 'secondary'
                      assign button_class = 'button button--secondary'
                    when 'icon'
                      assign button_class = 'link with--icon'
                    else
                      assign button_class = 'link'
                  endcase
                %}
                {% if block.settings.link_label != blank %}
                  <div class="promo--banner-content--button">
                    <a
                      class="{{ button_class }} {% unless block.settings.button_type == "icon" %} button--{{ block.settings.button_size }} {% endunless %} {% if block.settings.button_icon %} button--with-icon{% endif %}"
                      {% if block.settings.link == blank %}
                        role="link" aria-disabled="true"
                      {% else %}
                        href="{{ block.settings.link }}"
                      {% endif %}
                    >
                      {{- block.settings.link_label | escape }}
                      {% if block.settings.button_icon %}
                        <span class="button--icon button--icon-right"> {% render 'hooktheme-icon-chevron-right' %}</span>
                      {% endif %}
                    </a>
                  </div>
                {% endif %}
              </div>
              <!-- Promo Banner Content ./ -->

            {% when 'image' %}
              <!-- Promo banner media -->
              <div class="promo--banner-media-wrapper" {{ block.shopify_attributes }}>
                {% if block.settings.banner_link != blank and block.settings.image != blank %}
                  <a href="{{ block.settings.banner_link }}" class="promo--banner-media-link">
                {% endif %}
                <div
                  class="promo--banner-media  promo-banner-height-{{ block.settings.desktop_banner_height }}-desktop  promo-banner-height-{{ block.settings.mobile_banner_height }}-mobile  {% if block.settings.image != blank %} media{% else %} placeholder{% endif %}"

                  style="
                    {%- if block.settings.mobile_image != blank -%} --mobile-image-ratio: {{ 1 | divided_by: block.settings.mobile_image.aspect_ratio | times: 100 }}%;{%- endif -%}
                    --main-image-ratio: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;
                  "
                >
                  {%- if block.settings.image != blank -%}
                    {%- capture sizes -%}{% if section.blocks.size == 1  %} (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 }}px, (min-width: 750px) calc(100vw - 130px) {% else %}(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2){% endif %}, calc(100vw - 50px){%- endcapture -%}
                    {% liquid
                      assign desktop_image_class = ''
                      if block.settings.mobile_image != blank
                        assign desktop_image_class = 'promo--banner-card-desktop-image'
                      endif
                    %}

                    {{
                      block.settings.image
                      | image_url: width: 1500
                      | image_tag:
                        loading: 'lazy',
                        sizes: sizes,
                        widths: '165, 360, 535, 750, 1070, 1500, 1700, 2200, 3000',
                        class: desktop_image_class
                    }}
                    {% if block.settings.mobile_image != blank %}
                      {{
                        block.settings.mobile_image
                        | image_url: width: 1420
                        | image_tag:
                          loading: 'lazy',
                          sizes: sizes,
                          widths: '165, 360, 535, 750, 1070, 1500, 1700, 2200, 3000',
                          class: 'promo-banner--card-mobile-image'
                      }}
                    {% endif %}
                  {%- else -%}
                    {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg-new' }}
                  {%- endif -%}
                </div>
                {% if block.settings.banner_link != blank and block.settings.image != blank %}
                  </a>
                {% endif %}
              </div>
              <!-- Promo banner media ./ -->
            {% when 'video' %}
              <div class="promo--banner-media-wrapper" {{ block.shopify_attributes }}>
                <div class="promo--banner-video-content-inner video--content-{{ block.settings.desktop_content_alignment }}">
                  {% render 'promo-banner-video', block: block %}
                </div>
              </div>
            {% when 'product_list' %}
              <div class="promo--banner-media-wrapper" {{ block.shopify_attributes }}>
                <div class="promo--banner-product-list-inner  product--content-align-{{ block.settings.desktop_content_alignment }}">
                  <div class="promo__banner--product-list {% if block.settings.round_corner %}image-corner-round{% endif %}">
                    {%- for product in block.settings.product_list -%}
                      {% render 'promo-banner-product',
                        product_card_product: product,
                        block: block,
                        show_link: block.settings.show_link
                      %}
                    {%- else -%}
                      {%- assign a = 1 -%}
                      {%- for i in (1..3) -%}
                        {%- liquid
                          assign product_item = 'product-apparel-' | append: a
                          assign a = a | plus: 1
                        -%}
                        <div class="promo--banner-product-media product--media-placeholder">
                          <div class="promo--banner-product-placeholder">
                            {{ product_item | placeholder_svg_tag: 'promo--banner-product-placeholder-svg' }}
                          </div>
                        </div>
                      {%- endfor -%}
                    {%- endfor -%}
                  </div>

                  {% if block.settings.heading != blank
                    or block.settings.text != blank
                    or block.settings.link_label != blank
                  %}
                    <div class="promo--banner-product-content">
                      <h2 class="promo--banner-content--heading {{ block.settings.heading_size }} mb-0">
                        {{ block.settings.heading }}
                      </h2>
                      <div class="promo--banner-content-text rte ">
                        {{ block.settings.text }}
                      </div>

                      {% liquid
                        case block.settings.button_type
                          when 'primary'
                            assign button_class = 'button button--primary'
                          when 'secondary'
                            assign button_class = 'button button--secondary'
                          when 'icon'
                            assign button_class = 'link with--icon'
                          else
                            assign button_class = 'link'
                        endcase
                      %}
                      {% if block.settings.link_label != blank %}
                        <div class="promo--banner-content--button">
                          <a
                            class="{{ button_class }} {% unless block.settings.button_type == "icon" %} button--{{ block.settings.button_size }} {% endunless %} {% if block.settings.button_icon %} button--with-icon{% endif %}"
                            {% if block.settings.link == blank %}
                              role="link" aria-disabled="true"
                            {% else %}
                              href="{{ block.settings.link }}"
                            {% endif %}
                          >
                            {{- block.settings.link_label | escape }}
                            {% if block.settings.button_icon %}
                              <span class="button--icon button--icon-right"> {% render 'hooktheme-icon-chevron-right' %}</span>
                            {% endif %}
                          </a>
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% when 'product' %}
              <div
                class="promo--banner-media-wrapper promo__banner--product  promo--banner-product-padding-{{ block.settings.card_padding_type }}"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.product != blank %}
                  {% render 'promo-banner-product-card',
                    product_card_product: block.settings.product,
                    block: block,
                    show_title: block.settings.show_title,
                    show_price: block.settings.show_price,
                    show_rating: block.settings.show_product_rating,
                    show_button: block.settings.show_button
                  %}
                {% else %}
                  <div class="promo--banner-product-card">
                    <div class="promo--banner-product-media product--media-placeholder">
                      {{ 'product-apparel-1' | placeholder_svg_tag: 'promo--banner-product-placeholder-svg' }}
                    </div>
                    <div class="promo--banner-product-card-content-inner">
                      <div class="h5 mb-0">Product Title</div>
                      <span class="h6  mb-0 product-placeholder--price">$29.99 <s>$99.99</s></span>
                    </div>
                  </div>
                {% endif %}
              </div>
            {% when 'countdown_timer' %}
              <div
                class="promo--banner-countdown-timer-wrapper promo-timer-alignment--{{ block.settings.desktop_content_alignment }}"
                {{ block.shopify_attributes }}
              >
                {%- liquid
                  assign countdown_timer = block.settings.countdown_year | append: '-' | append: block.settings.countdown_month | append: '-' | append: block.settings.countdown_days
                  assign countdown_timer_convert = countdown_timer | date: '%s'
                  assign today_date = 'now' | date: '%s'

                  assign timer = false
                  if countdown_timer_convert > today_date
                    assign timer = true
                  endif
                -%}
                <countdown-timer>
                  {% if timer %}
                    <div
                      class="promo--banner-countdown-timer d-flex countdown--timer-{{ block.settings.timer_style }} countdown--font-{{ block.settings.timer_size }}"
                      data-countdown="{{ block.settings.countdown_year }}-{{ block.settings.countdown_month }}-{{ block.settings.countdown_days }}"
                    >
                      <div class="countdown__item Days">
                        <span class="countdown__number">- -</span>
                        <span class="countdown__text">{{ 'products.product.countdown_timer.days' | t }}</span>
                      </div>
                      <div class="countdown__item Hrs">
                        <span class="countdown__number">- -</span>
                        <span class="countdown__text">{{ 'products.product.countdown_timer.hours' | t }}</span>
                      </div>
                      <div class="countdown__item Min">
                        <span class="countdown__number">- -</span>
                        <span class="countdown__text">{{ 'products.product.countdown_timer.minutes' | t }}</span>
                      </div>
                      <div class="countdown__item Sec">
                        <span class="countdown__number">- -</span>
                        <span class="countdown__text">{{ 'products.product.countdown_timer.seconds' | t }}</span>
                      </div>
                    </div>
                  {% else %}
                    <div class="promo--banner-countdown-timer d-flex  countdown--timer-{{ block.settings.timer_style }} countdown--font-{{ block.settings.timer_size }}">
                      <div class="countdown__item Days">
                        <span class="countdown__number">00</span>
                        <span class="countdown__text">{{ 'products.product.countdown_timer.days' | t }}</span>
                      </div>
                      <div class="countdown__item Hrs">
                        <span class="countdown__number">00</span>
                        <span class="countdown__text">{{ 'products.product.countdown_timer.hours' | t }}</span>
                      </div>
                      <div class="countdown__item Min">
                        <span class="countdown__number">00</span>
                        <span class="countdown__text">{{ 'products.product.countdown_timer.minutes' | t }}</span>
                      </div>
                      <div class="countdown__item Sec">
                        <span class="countdown__number">00</span>
                        <span class="countdown__text">{{ 'products.product.countdown_timer.seconds' | t }}</span>
                      </div>
                    </div>
                  {% endif %}
                </countdown-timer>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

 

{% schema %}
{
  "name": "Promo banner",
  "class": "promo--banner-section",
  "max_blocks": 3,
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Page width",
      "default": "container",
      "info": "It will affect on the larger screen",
      "options": [
        {
          "value": "container",
          "label": "Boxed"
        },
        {
          "value": "container-fluid",
          "label": "Full width"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_offset",
      "label": "Enable horizontal space",
      "default": true,
      "info": "It will work if you select the \"Full width\" of the page width"
    },
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "checkbox",
      "id": "show_image_bg",
      "label": "Show background image",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image",
      "visible_if": "{{ section.settings.show_image_bg}}"
    },
    {
      "type": "select",
      "id": "bg_desktop_height",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "small",
          "label": "t:sections.image-with-text.settings.height.options__2.label"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "t:sections.image-with-text.settings.height.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "Image height on desktop",
      "visible_if": "{{ section.settings.show_image_bg}}"
    },
    {
      "type": "checkbox",
      "id": "custom_mobile_height",
      "label": "Custom height on mobile",
      "default": false,
      "visible_if": "{{ section.settings.show_image_bg}}"
    },
    {
      "type": "range",
      "id": "auto_best_fit_height_mobile",
      "min": 100,
      "max": 600,
      "step": 5,
      "unit": "px",
      "label": "Auto best fit height on mobile",
      "default": 250,
      "visible_if": "{{ section.settings.show_image_bg}}"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "border",
      "label": "Enable border on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "border_mobile",
      "label": "Enable border on mobile",
      "default": true
    },
    {
      "type": "select",
      "id": "border_type",
      "options": [
        {
          "value": "solid",
          "label": "Outside solid"
        },
        {
          "value": "outline",
          "label": "Inside outline"
        }
      ],
      "default": "solid",
      "label": "Border type"
    },
    {
      "type": "checkbox",
      "id": "round_corner",
      "default": true,
      "label": "Round corner"
    },
    {
      "type": "header",
      "content": "Promo card"
    },
    {
      "type": "checkbox",
      "id": "desktop_space_on_promo_card",
      "label": "Enable left and right space on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mobile_space_on_promo_card",
      "label": "Enable left and right space on mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "paragraph",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "default": "Promo Description",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "heading",
          "default": "Promo banner",
          "label": "Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "hxl2",
              "label": "Heading 3XL"
            },
            {
              "value": "hxl",
              "label": "Heading 2XL"
            },
            {
              "value": "h0",
              "label": "Heading XL"
            },
            {
              "value": "h1",
              "label": "Heading 1"
            },
            {
              "value": "h2",
              "label": "Heading 2"
            },
            {
              "value": "h3",
              "label": "Heading 3"
            },
            {
              "value": "h4",
              "label": "Heading 4"
            },
            {
              "value": "h5",
              "label": "Heading 5"
            },
            {
              "value": "h6",
              "label": "Heading 6"
            }
          ],
          "default": "h1",
          "label": "Heading size"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Button label",
          "default": "Button label"
        },
        {
          "type": "checkbox",
          "id": "button_icon",
          "label": "Use arrow icon",
          "default": true
        },
        {
          "type": "select",
          "id": "button_type",
          "label": "Button type",
          "default": "icon",
          "options": [
            {
              "value": "primary",
              "label": "Solid button"
            },
            {
              "value": "secondary",
              "label": "Outline button"
            },
            {
              "value": "icon",
              "label": "Link button"
            }
          ]
        },
        {
          "type": "select",
          "id": "button_size",
          "label": "Button size",
          "default": "small",
          "info": "Works on the solid/outline button",
          "options": [
            {
              "value": "large",
              "label": "Large"
            },
            {
              "value": "medium",
              "label": "Medium"
            },
            {
              "value": "small",
              "label": "Small"
            }
          ]
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.multicolumn.blocks.column.settings.link.label"
        },
        {
          "type": "select",
          "id": "content_alignment",
          "options": [
