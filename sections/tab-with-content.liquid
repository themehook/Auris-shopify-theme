<link rel="stylesheet" href="{{ 'hooktheme-rte.css' | asset_url }}" media="print" onload="this.media='all'">
{{ 'section-title.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-grid.css' | asset_url | stylesheet_tag }}
{{ 'tab-with-content.css' | asset_url | stylesheet_tag }}
{{ 'video-section.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}
{{ 'featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-slider-navigation.css' | asset_url | stylesheet_tag }}
<noscript>{{ 'hooktheme-rte.css' | asset_url | stylesheet_tag }}</noscript>

{% liquid
  assign container = ''
  assign page_offset = false
  if section.settings.container == 'container'
    assign container = 'container'
  elsif section.settings.container == 'container-fluid'
    assign container = 'container-fluid'
    unless section.settings.show_offset
      assign page_offset = true
    endunless
  else
    assign container = 'container-fluid px-0'
  endif

  assign flex_align = 'justify-content-center'
  if section.settings.text_center == 'left'
    assign flex_align = 'justify-content-start'
  elsif section.settings.text_center == 'right'
    assign flex_align = 'justify-content-end'
  endif

%}

{%- style -%}
   .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
     --padding-top: {{ section.settings.mobile_padding_top }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      --padding-top: {{ section.settings.padding_top }}px;
    }
  }
    #MainContent > :first-child .section--top-space-{{ section.id }} {
     margin-top: calc(var(--header-height) * var(--transparent-header-show));
   }
{%- endstyle -%}


<script src="{{ 'section-tab-with-content.js' | asset_url }}" defer="defer"></script>

{%- comment -%} Quick View Assets - Conditional Loading {%- endcomment -%}
{%- if section.settings.show_quick_view_button -%}
  {{ 'hooktheme-quick-view.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'hooktheme-quick-view.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<div class="tab-width-content-section section-{{ section.id }}-padding section--top-space-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="{{ container }} {% if page_offset %}p-0{% endif %}">
    {% comment %} section header {% endcomment %}

    <div class="section-heading text-{{ section.settings.text_center }} mobile--text-{{ section.settings.mobile_text_center }}  {% if section.settings.heading != blank or section.settings.description != blank %} {% endif %} mb-30">
      {% if section.settings.heading_position == 'bottom' and section.settings.description != blank %}
        <span class="section-heading__sub_title">{{- section.settings.description -}}</span>
      {% endif %}
      <h2 class="section-heading__title {% if section.settings.heading_position == "top" and section.settings.description != blank %}heading__space--bottom{% endif %}  {% if section.settings.heading == blank or section.settings.button_position == 'top' %}mb-0{% endif %}">
        {{- section.settings.heading -}}
      </h2>
      {% if section.settings.heading_position == 'top' and section.settings.description != blank %}
        <span class="section-heading__sub_title">
          {{- section.settings.description -}}
        </span>
      {% endif %}
    </div>

    {% comment %} end section header {% endcomment %}

    {% comment %} Tab width content {% endcomment %}
    <div class="tab-width-content-container">
      <tab-width-content data-tab-display="{{ section.settings.tab_display_behaviour }}">
        <div class="tab-width-content-inner ">
          <div class="tab-width-content-list {{ flex_align }} text-{{ section.settings.text_center }} mobile--text-{{ section.settings.mobile_text_center }} {% if section.settings.tab_btn_border %}tabbed__tab--btn__border{% endif %}">
            {%- for block in section.blocks -%}
              {% case block.type %}
                {%- when 'banner-list' -%}
                  <button
                    class="tab-width-content-list-item {{ block.settings.item_title_size }} {% if forloop.first == true %}is--open{% endif %}"
                    data-tab-index="collage--tab-{{ block.id }}"
                    {{ block.shopify_attributes }}
                  >
                  <span class="tab--collage-item-label">{{ block.settings.heading }}</span>
                </button>
                {%- when 'video' -%}
                  <button
                    class="tab-width-content-list-item {{ block.settings.item_title_size }} {% if forloop.first == true %}is--open{% endif %}"
                    data-tab-index="collage--tab-{{ block.id }}"
                    {{ block.shopify_attributes }}
                  >
                    <span class="tab--collage-item-label">{{ block.settings.heading }}</span>
                  </button>
                
                {%- when 'image-text' -%}
                  <button
                    class="tab-width-content-list-item {{ block.settings.item_title_size }} {% if forloop.first == true %}is--open{% endif %}"
                    data-tab-index="collage--tab-{{ block.id }}"
                    {{ block.shopify_attributes }}
                  >
                    <span class="tab--collage-item-label">{{ block.settings.heading }}</span>
                  </button> 
                {%- when 'product' -%}
                  {% assign product = block.settings.product %}
                  <button
                    class="tab-width-content-list-item {{ block.settings.item_title_size }} {% if forloop.first == true %}is--open{% endif %}"
                    data-tab-index="collage--tab-{{ block.id }}"
                    {{ block.shopify_attributes }}
                  >
                    {% if block.settings.heading != blank %}
                      <span class="tab--collage-item-label">{{ block.settings.heading }}</span>
                    {% elsif product != blank %}
                      <span class="tab--collage-item-label">
                        {{ product.title }}
                      </span>
                    {% else %}
                      <span class="tab--collage-item-label">{{- 'onboarding.product_title' | t -}}</span>
                    {% endif %}
                  </button>
              {% endcase %}
            {% endfor %}
          </div>
          <div class="tab--width--main-content">
            <div class="tab-width-content-media-container {% if section.settings.snow_fall %}snow--fall{% endif %}">
              {%- for block in section.blocks -%}
                {% case block.type %}
                  {%- when 'banner-list' -%}
                    <div
                      class="single-tab-width-content-wrapper {% if forloop.first == true %}is--open{% endif %}"
                      data-tab-index="collage--tab-{{ block.id }}"
                      {{ block.shopify_attributes }}
                    >
                      {% liquid
                        assign button_class = ''
                          case block.settings.button_type
                          when 'primary'
                            assign button_class = 'button button--primary'
                          when 'secondary'
                            assign button_class = 'button button--secondary'
                          when 'icon'
                            assign button_class = 'link with--icon'
                          else
                            assign button_class = 'link'
                          endcase
                        %}
                        {% liquid
                        assign content_position = 'align-items-start'
                          if block.settings.content_position == 'middle'
                            assign content_position = 'align-items-center'
                          elsif block.settings.content_position == 'bottom'
                            assign content_position = 'align-items-end'
                          endif

                          assign content_alignment = ''
                          assign align_self = 'flex-start'
                          if block.settings.content_alignment == 'center'
                            assign content_alignment = 'justify-content-center text-center'
                            assign align_self = 'center'
                          elsif block.settings.content_alignment == 'right'
                            assign content_alignment = 'text-right'
                            assign align_self = 'flex-end'
                          endif
                      %}
                      {% liquid
                        assign desktop_columns = block.settings.desktop_columns | default: '3'
                        case desktop_columns
                          when '1'
                            assign column_class = 'col-12'
                          when '2'
                            assign column_class = 'col-md-6 col-sm-6 col-12'
                          else
                            assign column_class = 'col-md-4 col-sm-6 col-12'
                        endcase
                      %}
                      <div class="tab--content--banner-list row">
                        <div class="{{ column_class }} mb-20">
                          <div class="tab-content-banner-list-item color-{{ block.settings.banner_color_scheme1 }} {% if block.settings.round_corner %} rounded--image {% endif %}">
                            {% if block.settings.enble_entire_link and block.settings.link %}
                              <a
                                {% if block.settings.link %}
                                  href="{{ block.settings.link }}"
                                {% else %}
                                  role="link"
                                {% endif %}
                                class="d-block"
                              >
                            {%- endif %}
                            <div
                              class="tab-content-banner-list-item-overlay {% if block.settings.round_corner %} rounded--image {% endif %}"
                              style="
                                    --banner-list-media-overlay-opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
                                {% if block.settings.overlay_gradient_color != blank %}
                                    --gradient-overlay-color: {{ block.settings.overlay_gradient_color }};
                                {% endif %}
                              "
                            >
                              {%- liquid
                                assign sizes = '100vw'
                                assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                              -%}
                              <div
                                class="tab-content-banner-list--media  media--{{ block.settings.image_ratio }} {% if block.settings.banner_image_1 != blank or block.settings.banner_video_1 != blank %}media--transparent media{% else %} placeholder {% endif %} {% if block.settings.round_corner %} rounded--image {% endif %}"
                                  {% if block.settings.image_ratio == 'adapt' %}
                                    style="
                                      {% if block.settings.banner_image_1 != blank %}
                                        --desktop-image-ratio: {{ 1 | divided_by: block.settings.banner_image_1.aspect_ratio | times: 100 }}%;
                                        {% if block.settings.banner_mobile_image_1 != blank %}
                                          --mobile-image-ratio: {{ 1 | divided_by: block.settings.banner_mobile_image_1.aspect_ratio | times: 100 }}%;
                                        {% else %}
                                          --mobile-image-ratio: {{ 1 | divided_by: block.settings.banner_image_1.aspect_ratio | times: 100 }}%;
                                        {% endif %}
                                      {% elsif block.settings.banner_video_1 != blank %}
                                        --desktop-image-ratio: {{ 1 | divided_by: block.settings.banner_video_1.aspect_ratio | times: 100 }}%;
                                        --mobile-image-ratio: {{ 1 | divided_by: block.settings.banner_video_1.aspect_ratio | times: 100 }}%;
                                      {% endif %}
                                    "
                                  {% endif %}
                              >
                                {%- if block.settings.banner_video_1 != blank -%}
                                  {{ block.settings.banner_video_1 | video_tag: autoplay: true, loop: true, controls: false, muted: true }}
                                {%- elsif block.settings.banner_image_1 != blank -%}
                                  {{
                                    block.settings.banner_image_1
                                    | image_url: width: 1420
                                    | image_tag: loading: 'lazy', 
                                      sizes: sizes, 
                                      widths: '275, 550, 710, 1420',
                                      class: 'banner--card-desktop-image'
                                  }}
                                  {% if block.settings.banner_mobile_image_1 != blank %}
                                    {%- capture sizes_mobile -%}calc(100vw - 30px){%- endcapture -%}
                                    {{
                                      block.settings.banner_mobile_image_1
                                      | image_url: width: 1420
                                      | image_tag:
                                        loading: 'lazy',
                                        sizes: sizes_mobile,
                                        widths: '275, 550, 710, 1420',
                                        class: 'banner--card-mobile-image'
                                    }}
                                  {% endif %}
                                {%- else -%}
                                  {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg-new' }}
                                {%- endif -%}
                              </div>
                              <div
                                class="tab-width-banner-list-content d-flex {{ content_alignment }} {{ content_position }}  {% if block.settings.show_content_below_image %} show__content--image-below{% else %}banner--list-padded-{{ block.settings.card_padding }} {% endif %}"
                              >
                                <div class="tab-width-banner-list-content-inner"
                                  style="
                                    --content-align-self: {{ align_self }};
                                  "
                                >
                                  {% if block.settings.banner_list_subheading1 != blank %}
                                    <div class="tab-width-banner-list-subheading">
                                      {{ block.settings.banner_list_subheading1 }}
                                    </div>
                                  {% endif %}
                                  {%- if block.settings.banner_list_titile1 != blank -%}
                                    <h3 class="tab-width-banner-list-heading mb-0 {{ block.settings.card_title_size }}">
                                      {{
                                        block.settings.banner_list_titile1
                                        | replace: 'p>', 'span>'
                                        | replace: 'h1>', 'span>'
                                        | replace: 'h2>', 'span>'
                                        | replace: 'h3>', 'span>'
                                        | replace: 'h4>', 'span>'
                                        | replace: 'h5>', 'span>'
                                        | replace: 'h6>', 'span>'
                                      }}
                                    </h3>
                                  {%- endif -%}
                                  {%- if block.settings.banner_list_text1 != blank -%}
                                    <div class="rte tab-width-banner-list-text">
                                      {{
                                        block.settings.banner_list_text1
                                        | replace: 'p>', 'span>'
                                        | replace: 'h1>', 'span>'
                                        | replace: 'h2>', 'span>'
                                        | replace: 'h3>', 'span>'
                                        | replace: 'h4>', 'span>'
                                        | replace: 'h5>', 'span>'
                                        | replace: 'h6>', 'span>'
                                      }}
                                    </div>
                                  {%- endif -%}
                                  
                                  {% comment %} Button 1 {% endcomment %}
                                {% if block.settings.banner_list_button1 != blank %}
                                  {% if block.settings.enble_entire_link %}
                                    <span class="tab-width-banner-list-btn {{ button_class }} {% unless block.settings.button_type == 'icon' %}button--{{ block.settings.button_size }}{% endunless %} {% if block.settings.button_1_icon %} button--with-icon{% endif %}">
                                        {{- block.settings.banner_list_button1 | escape }}
                                        {% if block.settings.button_1_icon %}
                                          <span class="button--icon button--icon-right">{% render 'hooktheme-icon-chevron-right' %}</span>
                                        {% endif %}
                                    </span>
                                  {% else %}
                                    <a
                                        {% if block.settings.link == blank %}
                                          role="link" aria-disabled="true"
                                        {% else %}
                                          href="{{ block.settings.link }}"
                                        {% endif %}
                                        class="tab-width-banner-list-btn {{ button_class }} {% unless block.settings.button_type == 'icon' %}button--{{ block.settings.button_size }}{% endunless %} {% if block.settings.button_1_icon %} button--with-icon{% endif %}"
                                      >
                                        {{- block.settings.banner_list_button1 | escape }}
                                        {% if block.settings.button_1_icon %}
                                          <span class="button--icon button--icon-right">{% render 'hooktheme-icon-chevron-right' %}</span>
                                        {% endif %}
                                      </a>
                                  {% endif %}
                                {% endif %}
                                  {% comment %} Button 1 end {% endcomment %}
                                </div>
                              </div>
                            </div>
                            {% if block.settings.enble_entire_link and block.settings.link %} </a>{% endif %}
                          </div>
                        </div>
                        {% if desktop_columns == '2' or desktop_columns == '3' %}
                          <div class="{{ column_class }} mb-20">
                            <div class="tab-content-banner-list-item color-{{ block.settings.banner_color_scheme2 }} {% if block.settings.round_corner %} rounded--image {% endif %}">
                              {% if block.settings.enble_entire_link and block.settings.link %}
                                <a
                                  {% if block.settings.link %}
                                    href="{{ block.settings.link }}"
                                  {% else %}
                                    role="link"
                                  {% endif %}
                                  class="d-block"
                                >
                              {%- endif %}
                              <div
                                class="tab-content-banner-list-item-overlay {% if block.settings.round_corner %} rounded--image {% endif %}"
                                style="
                                      --banner-list-media-overlay-opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
                                  {% if block.settings.overlay_gradient_color != blank %}
                                      --gradient-overlay-color: {{ block.settings.overlay_gradient_color }};
                                  {% endif %}
                                "
                              >
                                {%- liquid
                                  assign sizes = '100vw'
                                  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                                -%}
                                <div
                                  class="tab-content-banner-list--media  media--{{ block.settings.image_ratio }} {% if block.settings.banner_image_2 != blank or block.settings.banner_video_2 != blank %}media--transparent media{% else %} placeholder {% endif %} {% if block.settings.round_corner %} rounded--image {% endif %}"
                                    {% if block.settings.image_ratio == 'adapt' %}
                                      style="
                                        {% if block.settings.banner_image_2 != blank %}
                                          --desktop-image-ratio: {{ 1 | divided_by: block.settings.banner_image_2.aspect_ratio | times: 100 }}%;
                                          {% if block.settings.banner_mobile_image_2 != blank %}
                                            --mobile-image-ratio: {{ 1 | divided_by: block.settings.banner_mobile_image_2.aspect_ratio | times: 100 }}%;
                                          {% else %}
                                            --mobile-image-ratio: {{ 1 | divided_by: block.settings.banner_image_2.aspect_ratio | times: 100 }}%;
                                          {% endif %}
                                        {% elsif block.settings.banner_video_2 != blank %}
                                          --desktop-image-ratio: {{ 1 | divided_by: block.settings.banner_video_2.aspect_ratio | times: 100 }}%;
                                          --mobile-image-ratio: {{ 1 | divided_by: block.settings.banner_video_2.aspect_ratio | times: 100 }}%;
                                        {% endif %}
                                      "
                                    {% endif %}
                                >
                                  {%- if block.settings.banner_video_2 != blank -%}
                                    {{
                                      block.settings.banner_video_2
                                      | video_tag: autoplay: true, loop: true, controls: false, muted: true
                                    }}
                                  {%- elsif block.settings.banner_image_2 != blank -%}
                                    {{
                                      block.settings.banner_image_2
                                      | image_url: width: 1420
                                      | image_tag: 
                                        loading: 'lazy', 
                                        sizes: sizes, 
                                        widths: '275, 550, 710, 1420',
                                        class: 'banner--card-desktop-image'
                                    }}
                                    {% if block.settings.banner_mobile_image_2 != blank %}
                                      {%- capture sizes_mobile -%}calc(100vw - 30px){%- endcapture -%}
                                      {{
                                        block.settings.banner_mobile_image_2
                                        | image_url: width: 1420
                                        | image_tag:
                                          loading: 'lazy',
                                          sizes: sizes_mobile,
                                          widths: '275, 550, 710, 1420',
                                          class: 'banner--card-mobile-image'
                                      }}
                                    {% endif %}
                                  {%- else -%}
                                    {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg-new' }}
                                  {%- endif -%}
                                </div>
                                <div
                                  class="tab-width-banner-list-content d-flex {{ content_alignment }} {{ content_position }}  {% if block.settings.show_content_below_image %} show__content--image-below{% else %}banner--list-padded-{{ block.settings.card_padding }} {% endif %}"
                                >
                                  <div class="tab-width-banner-list-content-inner"
                                    style="
                                      --content-align-self:  {{ align_self }};
                                    "
                                  >
                                    {% if block.settings.banner_list_subheading2 != blank %}
                                      <div class="tab-width-banner-list-subheading">
                                        {{ block.settings.banner_list_subheading2 }}
                                      </div>
                                    {% endif %}
                                    {%- if block.settings.banner_list_titile2 != blank -%}
                                      <h3 class="tab-width-banner-list-heading mb-0 {{ block.settings.card_title_size }}">
                                        {{
                                          block.settings.banner_list_titile2
                                          | replace: 'p>', 'span>'
                                          | replace: 'h1>', 'span>'
                                          | replace: 'h2>', 'span>'
                                          | replace: 'h3>', 'span>'
                                          | replace: 'h4>', 'span>'
                                          | replace: 'h5>', 'span>'
                                          | replace: 'h6>', 'span>'
                                        }}
                                      </h3>
                                    {%- endif -%}
                                    {%- if block.settings.banner_list_text2 != blank -%}
                                      <div class="rte tab-width-banner-list-text">
                                        {{
                                          block.settings.banner_list_text2
                                          | replace: 'p>', 'span>'
                                          | replace: 'h1>', 'span>'
                                          | replace: 'h2>', 'span>'
                                          | replace: 'h3>', 'span>'
                                          | replace: 'h4>', 'span>'
                                          | replace: 'h5>', 'span>'
                                          | replace: 'h6>', 'span>'
                                        }}
                                      </div>
                                    {%- endif -%}

                                    {% comment %} Button 2 {% endcomment %}
                                    {% if block.settings.banner_list_button2 != blank %}
                                      {% if block.settings.enble_entire_link %}
                                        <span class="tab-width-banner-list-btn {{ button_class }} {% unless block.settings.button_type == 'icon' %}button--{{ block.settings.button_size }}{% endunless %} {% if block.settings.button_2_icon %} button--with-icon{% endif %}">
                                          {{- block.settings.banner_list_button2 | escape }}
                                          {% if block.settings.button_2_icon %}
                                            <span class="button--icon button--icon-right">{% render 'hooktheme-icon-chevron-right' %}</span>
                                          {% endif %}
                                        </span>
                                      {% else %}
                                        <a
                                            {% if block.settings.link == blank %}
                                              role="link" aria-disabled="true"
                                            {% else %}
                                              href="{{ block.settings.link }}"
                                            {% endif %}
                                            class="tab-width-banner-list-btn {{ button_class }} {% unless block.settings.button_type == 'icon' %}button--{{ block.settings.button_size }}{% endunless %} {% if block.settings.button_2_icon %} button--with-icon{% endif %}"
                                          >
                                            {{- block.settings.banner_list_button2 | escape }}
                                            {% if block.settings.button_2_icon %}
                                              <span class="button--icon button--icon-right">{% render 'hooktheme-icon-chevron-right' %}</span>
                                            {% endif %}
                                          </a>
                                      {% endif %}
                                    {% endif %}
                                    {% comment %} Button 2 end {% endcomment %}
                                  </div>
                                </div>
                              </div>
                              {% if block.settings.enble_entire_link and block.settings.link %} </a>{% endif %}
                            </div>
                          </div>
                        {% endif %}
                        {% if desktop_columns == '3' %}
                          <div class="{{ column_class }} mb-20">
                            <div class="tab-content-banner-list-item color-{{ block.settings.banner_color_scheme3 }} {% if block.settings.round_corner %} rounded--image {% endif %}">
                              {% if block.settings.enble_entire_link and block.settings.link %}
                                <a
                                  {% if block.settings.link %}
                                    href="{{ block.settings.link }}"
                                  {% else %}
                                    role="link"
                                  {% endif %}
                                  class="d-block"
                                >
                              {%- endif %}
                              <div
                                class="tab-content-banner-list-item-overlay {% if block.settings.round_corner %} rounded--image {% endif %}"
                                style="
                                      --banner-list-media-overlay-opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
                                  {% if block.settings.overlay_gradient_color != blank %}
                                      --gradient-overlay-color: {{ block.settings.overlay_gradient_color }};
                                  {% endif %}
                                "
                              >
                                {%- liquid
                                  assign sizes = '100vw'
                                  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                                -%}
                                <div
                                  class="tab-content-banner-list--media  media--{{ block.settings.image_ratio }} {% if block.settings.banner_image_3 != blank or block.settings.banner_video_3 != blank %}media--transparent media{% else %} placeholder {% endif %} {% if block.settings.round_corner %} rounded--image {% endif %}"
                                    {% if block.settings.image_ratio == 'adapt' %}
                                      style="
                                        {% if block.settings.banner_image_3 != blank %}
                                          --desktop-image-ratio: {{ 1 | divided_by: block.settings.banner_image_3.aspect_ratio | times: 100 }}%;
                                          {% if block.settings.banner_mobile_image_3 != blank %}
                                            --mobile-image-ratio: {{ 1 | divided_by: block.settings.banner_mobile_image_3.aspect_ratio | times: 100 }}%;
                                          {% else %}
                                            --mobile-image-ratio: {{ 1 | divided_by: block.settings.banner_image_3.aspect_ratio | times: 100 }}%;
                                          {% endif %}
                                        {% elsif block.settings.banner_video_3 != blank %}
                                          --desktop-image-ratio: {{ 1 | divided_by: block.settings.banner_video_3.aspect_ratio | times: 100 }}%;
                                          --mobile-image-ratio: {{ 1 | divided_by: block.settings.banner_video_3.aspect_ratio | times: 100 }}%;
                                        {% endif %}
                                      "
                                    {% endif %}
                                >
                                  {%- if block.settings.banner_video_3 != blank -%}
                                    {{
                                      block.settings.banner_video_3
                                      | video_tag: autoplay: true, loop: true, controls: false, muted: true
                                    }}
                                  {%- elsif block.settings.banner_image_3 != blank -%}
                                    {{
                                      block.settings.banner_image_3
                                      | image_url: width: 1420
                                      | image_tag: 
                                        loading: 'lazy', 
                                        sizes: sizes, 
                                        widths: '275, 550, 710, 1420',
                                        class: 'banner--card-desktop-image'
                                    }}
                                    {% if block.settings.banner_mobile_image_3 != blank %}
                                      {%- capture sizes_mobile -%}calc(100vw - 30px){%- endcapture -%}
                                      {{
                                        block.settings.banner_mobile_image_3
                                        | image_url: width: 1420
                                        | image_tag:
                                          loading: 'lazy',
                                          sizes: sizes_mobile,
                                          widths: '275, 550, 710, 1420',
                                          class: 'banner--card-mobile-image'
                                      }}
                                    {% endif %}
                                  {%- else -%}
                                    {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg-new' }}
                                  {%- endif -%}
                                </div>
                                <div
                                  class="tab-width-banner-list-content d-flex {{ content_alignment }} {{ content_position }}  {% if block.settings.show_content_below_image %} show__content--image-below{% else %}banner--list-padded-{{ block.settings.card_padding }} {% endif %}"
                                >
                                  <div class="tab-width-banner-list-content-inner"
                                    style="
                                      --content-align-self:  {{ align_self }};
                                    "
                                  >
                                    {% if block.settings.banner_list_subheading3 != blank %}
                                      <div class="tab-width-banner-list-subheading">
                                        {{ block.settings.banner_list_subheading3 }}
                                      </div>
                                    {% endif %}
                                    {%- if block.settings.banner_list_titile3 != blank -%}
                                      <h3 class="tab-width-banner-list-heading mb-0 {{ block.settings.card_title_size }}">
                                        {{
                                          block.settings.banner_list_titile3
                                          | replace: 'p>', 'span>'
                                          | replace: 'h1>', 'span>'
                                          | replace: 'h2>', 'span>'
                                          | replace: 'h3>', 'span>'
                                          | replace: 'h4>', 'span>'
                                          | replace: 'h5>', 'span>'
                                          | replace: 'h6>', 'span>'
                                        }}
                                      </h3>
                                    {%- endif -%}
                                    {%- if block.settings.banner_list_text3 != blank -%}
                                      <div class="rte tab-width-banner-list-text">
                                        {{
                                          block.settings.banner_list_text3
                                          | replace: 'p>', 'span>'
                                          | replace: 'h1>', 'span>'
                                          | replace: 'h2>', 'span>'
                                          | replace: 'h3>', 'span>'
                                          | replace: 'h4>', 'span>'
                                          | replace: 'h5>', 'span>'
                                          | replace: 'h6>', 'span>'
                                        }}
                                      </div>
                                    {%- endif -%}

                                    {% comment %} Button 3 {% endcomment %}
                                    {% if block.settings.banner_list_button3 != blank %}
                                      {% if block.settings.enble_entire_link %}
                                        <span class="tab-width-banner-list-btn {{ button_class }} {% unless block.settings.button_type == 'icon' %}button--{{ block.settings.button_size }}{% endunless %} {% if block.settings.button_3_icon %} button--with-icon{% endif %}">
                                          {{- block.settings.banner_list_button3 | escape }}
                                          {% if block.settings.button_3_icon %}
                                            <span class="button--icon button--icon-right">{% render 'hooktheme-icon-chevron-right' %}</span>
                                          {% endif %}
                                        </span>
                                      {% else %}
                                        <a
                                            {% if block.settings.link == blank %}
                                              role="link" aria-disabled="true"
                                            {% else %}
                                              href="{{ block.settings.link }}"
                                            {% endif %}
                                            class="tab-width-banner-list-btn {{ button_class }} {% unless block.settings.button_type == 'icon' %}button--{{ block.settings.button_size }}{% endunless %} {% if block.settings.button_3_icon %} button--with-icon{% endif %}"
                                          >
                                            {{- block.settings.banner_list_button3 | escape }}
                                            {% if block.settings.button_3_icon %}
                                              <span class="button--icon button--icon-right">{% render 'hooktheme-icon-chevron-right' %}</span>
                                            {% endif %}
                                          </a>
                                      {% endif %}
                                    {% endif %}
                                    {% comment %} Button 3 end {% endcomment %}
                                  </div>
                                </div>
                              </div>
                              {% if block.settings.enble_entire_link and block.settings.link %} </a>{% endif %}
                            </div>
                          </div>
                        {% endif %}
                      </div>
                    </div>
                  {%- when 'video' -%}
                    <div
                      class="single-tab-width-content-wrapper {% if forloop.first == true %}is--open{% endif %}"
                      data-tab-index="collage--tab-{{ block.id }}"
                      {{ block.shopify_attributes }}
                    >

                      {% liquid
                      assign video_id = block.settings.play_video.id | default: block.settings.video_url.id
                      assign video_alt = block.settings.video.alt | default: block.settings.description
                      assign alt = 'sections.video.load_video' | t: description: video_alt | escape
                      assign poster = block.settings.play_video.preview_image | default: block.settings.cover_image
                      assign sizes = '100vw'

                      if block.settings.play_video != null
                        assign ratio_diff = block.settings.play_video.aspect_ratio | minus: poster.aspect_ratio | abs
                        if ratio_diff < 0.01 and ratio_diff > 0
                          assign fix_ratio = true
                        endif
                      endif
                    %}
                      <div class="tab-width-content--video {% if block.settings.round_corner %}rounded--image{% endif %}">
                        <noscript>
                          <div
                            class="video-section__media video--banner__media--{{ block.settings.height }}"
                            {% if poster != null and block.settings.height == 'adapt' %}
                              style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
                            {% endif %}
                          >
                            {%- if block.settings.play_video == null and block.settings.video_url != null -%}
                              <a
                                href="{{ block.settings.video_url }}"
                                class="video-section__poster media media--transparent{% if poster == null %} video-section__placeholder{% endif %}"
                              >
                                {%- if poster != null -%}
                                  {{
                                    poster
                                    | image_url: width: 3840
                                    | image_tag:
                                      loading: 'lazy',
                                      sizes: sizes,
                                      widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                                      alt: alt
                                  }}
                                {%- else -%}
                                  {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                                {%- endif -%}
                              </a>
                            {%- else -%}
                              {{
                                block.settings.play_video
                                | video_tag:
                                  image_size: '1100x',
                                  loop: block.settings.enable_video_looping,
                                  controls: true,
                                  muted: false
                              }}
                            {%- endif -%}
                          </div>
                        </noscript>
                        <deferred-media
                          class="video-section__media deferred-media no-js-hidden gradient video--banner__media--{{ block.settings.height }} {% if poster == null and block.settings.height == 'adapt' %} video-section__placeholder{% endif %}  {% if fix_ratio %} media-fit-cover{% endif %}"
                          data-media-id="{{ video_id }}"
                          {% if poster != null and block.settings.height == 'adapt' %}
                            style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
                          {% endif %}
                        >
                          <button
                            id="Deferred-Poster-Modal-{{ video_id }}"
                            class="video-section__poster media deferred-media__poster"
                            type="button"
                            aria-label="{{ alt }}"
                          >
                            {%- if poster != null -%}
                              {{
                                poster
                                | image_url: width: 3840
                                | image_tag:
                                  loading: 'lazy',
                                  sizes: sizes,
                                  widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                                  alt: alt
                              }}
                            {%- else -%}
                              {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                            {%- endif -%}
                            <span class="deferred-media__poster-button motion-reduce banner__bideo--play">
                              <span class="banner__bideo--play__icon">
                                {%- render 'hooktheme-icon-play' -%}
                              </span>
                            </span>
                          </button>
                          <template>
                            {%- if block.settings.play_video == null and block.settings.video_url != null -%}
                              {%- liquid
                                assign loop = ''
                                if block.settings.enable_video_looping
                                  assign loop = '&loop=1&playlist=' | append: video_id
                                endif
                              -%}
                              {%- if block.settings.video_url.type == 'youtube' -%}
                                <iframe
                                  src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&autoplay=1{{ loop }}"
                                  class="js-youtube"
                                  allow="autoplay; encrypted-media"
                                  allowfullscreen
                                  title="{{ block.settings.description | escape }}"
                                ></iframe>
                              {%- else -%}
                                <iframe
                                  src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1{{ loop }}"
                                  class="js-vimeo"
                                  allow="autoplay; encrypted-media"
                                  allowfullscreen
                                  title="{{ block.settings.description | escape }}"
                                ></iframe>
                              {%- endif -%}
                            {%- else -%}
                              {{
                                block.settings.play_video
                                | video_tag:
                                  image_size: '1100x',
                                  autoplay: true,
                                  loop: block.settings.enable_video_looping,
                                  controls: true,
                                  muted: false
                              }}
                            {%- endif -%}
                          </template>
                        </deferred-media>
                      </div>
                    </div>
                  
                  {%- when 'image-text' -%}
                    <div
                      class="single-tab-width-content-wrapper {% if forloop.first == true %}is--open{% endif %}"
                      data-tab-index="collage--tab-{{ block.id }}"
                      {{ block.shopify_attributes }}
                    >
                      {% liquid
                        assign column_width = block.settings.desktop_image_width
                        case column_width
                          when 'small'
                            assign flex_image_grow = '0'
                            assign flex_content_grow = '1'
                          when 'medium'
                            assign flex_image_grow = '1'
                            assign flex_content_grow = '1'
                          else
                            assign flex_image_grow = '1'
                            assign flex_content_grow = '0'
                        endcase

                        assign desktop_content_position_class = block.settings.image_desktop_content_position
                        case desktop_content_position_class
                          when 'bottom'
                            assign desktop_content_alignment_class_assign = 'align-items-end'
                          when 'middle'
                            assign desktop_content_alignment_class_assign = 'align-items-center'
                          else
                            assign desktop_content_alignment_class_assign = 'align-items-start'
                        endcase

                        assign mobile_content_alignment_class = block.settings.mobile_content_alignment

                        case mobile_content_alignment_class
                          when 'left'
                            assign mobile_content_alignment_class_assign = 'mobile__text-left'
                          when 'center'
                            assign mobile_content_alignment_class_assign = 'mobile__text-center'
                          else
                            assign mobile_content_alignment_class_assign = 'mobile__text-right'
                        endcase
                        if block.settings.image_full_width
                        assign column_class = 'col-12'
                      else
                        assign column_class = 'col-md-4'
                      endif
                      %}
                      <div class="tab-content-image-text color-{{ block.settings.image_text_color_scheme }} {% if block.settings.text_image_layout == "text_first" %} desktop-row-reverse {% endif %} d-flex flex-wrap {% if block.settings.round_corner %} content-box-rounded {% endif %}">
                        <div class="tab-content-image--thumbnail {{ column_class }} flex-grow-{{ flex_image_grow }}">
                          <div
                            class="tab-content-image-text-media tab-content-image-text-media--{{ block.settings.text_image_height }}  {% if block.settings.image_text_image != blank %}media{% else %}tab-content-image-text-media--placeholder placeholder{% endif %} {% if block.settings.round_corner %} rounded--image {% endif %}"
                            {% if block.settings.text_image_height == 'adapt' and block.settings.image_text_image != blank %}
                              style="padding-bottom: {{ 1 | divided_by: block.settings.image_text_image.aspect_ratio | times: 100 }}%;"
                            {% endif %}
                          >
                            {%- if block.settings.image_text_image != blank -%}
                              }
                              {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
                              {%- capture sizes -%}
                                  (min-width: {{ settings.container_lg_width }}px) {{ settings.container_lg_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), 100vw
                                {%- endcapture -%}

                              {{
                                block.settings.image_text_image
                                | image_url: width: 1500
                                | image_tag: sizes: sizes, widths: widths
                              }}
                            {%- else -%}
                              {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg-new' }}
                            {%- endif -%}
                          </div>
                        </div>
                        <div class=" {{ column_class }} flex-grow-{{ flex_content_grow }} d-flex {{ desktop_content_alignment_class_assign }}">
                          <div class="tab-content-image-width--content {% if block.settings.image_content_padding != "none" %} tab-image-with-text-padding-{{ block.settings.image_content_padding }}{% else %} {% if block.settings.layout == "text_first" and block.settings.desktop_image_width != "large" %}tab-image-with-text-padding--left-false{% endif %}{% endif %} text-{{ block.settings.image_desktop_content_alignment }}  {{ mobile_content_alignment_class_assign }}">
                            <p
                              class="tab-content-image-width--caption {{ block.settings.text_size }}"
                            >
                              {{ block.settings.image_text_caption | escape }}
                            </p>
                            <h2
                              class="tab-content-image-width__heading {{ block.settings.heading_size }} mb-0"
                            >
                              {{
                                block.settings.image_text_heading
                                | replace: 'p>', 'span>'
                                | replace: 'h1>', 'span>'
                                | replace: 'h2>', 'span>'
                                | replace: 'h3>', 'span>'
                                | replace: 'h4>', 'span>'
                                | replace: 'h5>', 'span>'
                                | replace: 'h6>', 'span>'
                              }}
                            </h2>

                            <div
                              class="tab-content-image-width--desc rte "
                            >
                              {{ block.settings.image_description }}
                            </div>
                            {% liquid
                              assign button_class = ''
                              case block.settings.button_style
                                when 'primary'
                                  assign button_class = 'button button--primary'
                                when 'secondary'
                                  assign button_class = 'button button--secondary'
                                when 'icon'
                                  assign button_class = 'link with--icon'
                                else
                                  assign button_class = 'link'
                              endcase
                            %}

                            {% if block.settings.button_label != blank %}
                              <div
                                class="button__wrapper {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                                {% if settings.animations_reveal_on_scroll %}
                                  data-cascade
                                  style="--animation-order: {{ forloop.index }};"
                                {% endif %}
                                {{ block.shopify_attributes }}
                              >
                                <a
                                  {% if block.settings.button_link == blank %}
                                    role="link" aria-disabled="true"
                                  {% else %}
                                    href="{{ block.settings.button_link }}"
                                  {% endif %}
                                  class="{{ button_class }} {% unless block.settings.button_type == 'icon' %}button--{{ block.settings.button_size }}{% endunless %} {% if block.settings.button_icon %} button--with-icon{% endif %}"
                                >
                                  {{- block.settings.button_label | escape }}
                                  {% if block.settings.button_icon %}
                                    <span class="button--icon button--icon-right">{% render 'hooktheme-icon-chevron-right' %}</span>
                                  {% endif %}
                                </a>
                              </div>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    </div>
                  {%- when 'product' -%}
                    <div
                      class="single-tab-width-content-wrapper {% if forloop.first == true %}is--open{% endif %}"
                      data-tab-index="collage--tab-{{ block.id }}"
                      {{ block.shopify_attributes }}
                    >

                      {%- liquid
                          assign productShowXl = block.settings.product_column
                          assign productShowLg = block.settings.product_column_laptop
                          assign productShowMd = block.settings.product_column_tablet
                          assign productShowSm = block.settings.product_column_mobile
                          assign sliderRows = block.settings.slider_rows
                          assign slideLoop = block.settings.slider_loop

                          assign slider_enable = block.settings.slider_enable
                          assign productItem = 'col mb-20'

                          if slider_enable
                            assign productItem = 'swiper-slide'
                            assign showPagination = block.settings.show_pagination
                            assign showNavigation = block.settings.show_navigation
                          endif    


                          assign collection = collections[block.settings.collection]
                          if block.settings.collection.all_products_count > block.settings.products_to_show
                            assign more_in_collection = true
                          endif

                          assign featured_product_limit = block.settings.products_to_show
                      -%}
                      {%- capture productWrapper -%}
                        {%- if slider_enable -%}
                          productSlider swiper
                        {%- else -%}
                          row row-cols-xl-{{ productShowXl }} row-cols-lg-{{ productShowLg }} row-cols-md-{{ productShowMd }} row-cols-{{ productShowSm }}
                        {%- endif -%}
                      {%- endcapture -%}
                      <div class= "tab-width-content--product"
                         data-section-id="{{ section.id }}"
                          data-section-type="product-slider"
                          data-slider-enable="{{ slider_enable }}"
                          {% if slider_enable %}
                            data-show-mobile="{{ productShowSm }}"
                            data-show-tablet="{{ productShowMd }}"
                            data-show-large="{{ productShowLg }}"
                            data-show-extra-large="{{ productShowXl }}"
                            data-slider-rows="{{sliderRows}}"
                            data-slide-loop="{{ slideLoop }}"
                          {% endif %}
                      >
                        <div class="product_slider_wrapper">
                          <div class="{{ productWrapper }} collection__product">
                            {%- if slider_enable -%}<div class="swiper-wrapper">{%- endif -%}
                            {%- for product in collection.products limit: featured_product_limit -%}
                              <div class="{{ productItem }}">
                                {% render 'product-card',
                                  product_card_product: product,
                                  section_id: section.id,
                                  media_size: block.settings.image_ratio,
                                  show_secondary_image: block.settings.show_secondary_image,
                                  show_vendor: block.settings.show_vendor,
                                  show_badge: block.settings.show_badges,
                                  show_cart_button: block.settings.show_cart_button,
                                  show_preorder_button: block.settings.show_preorder_button,
                                  show_quick_view: block.settings.show_quick_view_button,
                                  show_quick_compare: block.settings.show_compare_view_button,
                                  show_wishlist: block.settings.show_wishlist_button,
                                  show_countdown: block.settings.show_countdown,
                                  show_title: block.settings.show_title,
                                  show_price: block.settings.show_price,
                                  show_rating: block.settings.show_product_rating,
                                  card_style: block.settings.card_style,
                                  color_swatches: block.settings.color_swatches,
                                  color_scheme: block.settings.product_card_color_scheme,
                                  spacing: block.settings.product_card_spacing,
                                  corner_radius: block.settings.product_card_radius,
                                  show_border: block.settings.show_border,
                                  cart_button_type: block.settings.cart_button_type,
                                  action_buttons_position: block.settings.action_buttons_position,
                                  action_buttons_style: block.settings.action_button_style,
                                  show_always: block.settings.show_always,
                                  low_stock_value: block.settings.low_stock_value,
                                  minimum_amount_value: block.settings.minimum_amount_value,
                                  show_inventory_quantity: block.settings.show_inventory_quantity,
                                  show_inventory_status: block.settings.show_inventory_status,
                                  in_stock_color: block.settings.in_stock,
                                  out_of_stock_color: block.settings.out_of_stock,
                                  low_stock_color: block.settings.low_stock,
                                  continue_selling_color: block.settings.continue_selling
                                %}
                              </div>
                            {%- else -%}
                              {%- assign a = 1 -%}
                              {%- for i in (1..featured_product_limit) -%}
                                {%- liquid
                                  assign product_item = 'product-apparel-' | append: a
                                  assign a = a | plus: 1
                                -%}
                                {%- render 'product-card-placeholder',
                                  product_item: product_item,
                                  productItem: productItem,
                                  corner_radius: section.settings.product_card_radius
                                -%}
                                {%- liquid
                                  if a == 4
                                    assign a = 1
                                  endif
                                -%}
                              {%- endfor -%}
                            {%- endfor -%}
                            {%- if slider_enable -%}
                              </div>
                            {%- endif -%}
                          </div>

                          {%- if slider_enable -%}
                            {%- if showNavigation -%}
                              <div class="swiper-button-next product-slider--nav-button component--slider--nav">
                                {% render 'hooktheme-icon-chevron-right' %}
                              </div>
                              <div class="swiper-button-prev product-slider--nav-button component--slider--nav">
                                {% render 'hooktheme-icon-chevron-left' %}
                              </div>
                            {%- endif -%}
                            {%- if showPagination -%}
                              <div class="swiper-pagination product-slider--pagination"></div>
                            {%- endif -%}
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                {% endcase %}
              {% endfor %}
            </div>
          </div>
        </div>
      </tab-width-content>
    </div>
    {% comment %} Tab collager container end {% endcomment %}
  </div>
</div>

{% schema %}
{
  "name": "Tab with content",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Page width",
      "default": "container",
      "info": "It will affect on the larger screen",
      "options": [
        {
          "value": "container",
          "label": "Boxed"
        },
        {
          "value": "container-fluid",
          "label": "Full width"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_offset",
      "label": "Enable horizontal space",
      "default": true,
      "info": "It will work if you select the \"Full width\" of the page width"
    },
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Tab content",
      "label": "t:sections.featured-collection.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h1",
          "label": "Heading 1"
        },
        {
          "value": "h2",
          "label": "Heading 2"
        },
        {
          "value": "h3",
          "label": "Heading 3"
        },
        {
          "value": "h4",
          "label": "Heading 4"
        },
        {
          "value": "h5",
          "label": "Heading 5"
        },
        {
          "value": "h6",
          "label": "Heading 6"
        }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_position",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "top",
      "label": "Heading position"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "text_center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Desktop alignment"
    },
    {
      "type": "select",
      "id": "mobile_text_center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Mobile alignment"
    },
    {
      "type": "checkbox",
      "id": "tab_btn_border",
      "label": "Show border",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "tab_display_behaviour",
      "options": [
        {
          "value": "hover",
          "label": "On hover"
