{{ 'section-title.css' | asset_url | stylesheet_tag }}
{{ 'section-comparison-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'hooktheme-quick-view.js' | asset_url }}" defer="defer"></script>

<style>
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
</style>

{%- liquid
  assign section_color_scheme = section.settings.color_scheme
  assign container = 'container'
  if section.settings.layout == 'full-width'
    assign container = 'container-fluid'
  endif
  assign row_blocks = section.blocks | where: 'type', 'comparison_row'
-%}

<div
  class="comparison-product__section color-{{ section_color_scheme }} section-{{ section.id }}-padding"
  data-comparison-section="{{ section.id }}"
>
  <div class="{{ container }}">

    {%- comment -%} Section header: standard theme heading + view all (right) {%- endcomment -%}
    {%- assign show_view_all = section.settings.show_view_all -%}
    {%- if section.settings.heading != blank or section.settings.subtitle != blank or show_view_all -%}
      <div class="section--header-wrapper mb-50">
        <div class="section-heading text-{{ section.settings.text_center }} mobile--text-{{ section.settings.mobile_text_center }}">
          {% if section.settings.heading_position == 'bottom' and section.settings.subtitle != blank %}
            <span class="section-heading__sub_title">{{- section.settings.subtitle -}}</span>
          {% endif %}
          <h2 class="section-heading__title {% if section.settings.heading_position == "top" and section.settings.subtitle != blank %}heading__space--bottom{% endif %}  {% if section.settings.heading == blank or section.settings.button_position == 'top' %}mb-0{% endif %}">
            {{- section.settings.heading -}}
          </h2>
          {% if section.settings.heading_position == 'top' and section.settings.subtitle != blank %}
            <span class="section-heading__sub_title">
              {{- section.settings.subtitle -}}
            </span>
          {% endif %}
        </div>
        {%- if show_view_all and section.settings.view_all_label != blank -%}
          <div class="section__header--info">
            <a
              {% if section.settings.view_all_url != blank %}href="{{ section.settings.view_all_url }}"{% else %}href="#" aria-disabled="true"{% endif %}
              class="link with--icon button--not-underline{% if section.settings.view_all_button_icon %} button--with-icon{% endif %}"
            >
              {{- section.settings.view_all_label | escape -}}
              {%- if section.settings.view_all_button_icon -%}
                <span class="button--icon button--icon-right">{% render 'hooktheme-icon-arrow-right' %}</span>
              {%- endif -%}
            </a>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Product columns grid {%- endcomment -%}
    <div class="comparison-product__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product_column' -%}
          {%- render 'comparison-product-card',
            block: block,
            row_blocks: row_blocks,
            section: section
          -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

<script>
(function () {
  var sectionEl = document.querySelector('[data-comparison-section="{{ section.id }}"]');
  if (!sectionEl) return;

  var grid = sectionEl.querySelector('.comparison-product__grid');
  if (!grid) return;

  function resetHeights() {
    grid.querySelectorAll(
      '.comparison-product__image-wrap, .comparison-product__card-info, .comparison-product__quick-add-wrap, .comparison-product__row'
    ).forEach(function (el) { el.style.minHeight = ''; });
  }

  function equalizeGrid() {
    var cards = Array.prototype.slice.call(
      grid.querySelectorAll(':scope > .comparison-product__card')
    );
    if (cards.length < 2) return;

    resetHeights();

    [
      '.comparison-product__image-wrap',
      '.comparison-product__card-info',
      '.comparison-product__quick-add-wrap'
    ].forEach(function (sel) {
      var els = cards.map(function (c) { return c.querySelector(sel); }).filter(Boolean);
      if (!els.length) return;
      var maxH = Math.max.apply(null, els.map(function (el) {
        return el.getBoundingClientRect().height;
      }));
      els.forEach(function (el) { el.style.minHeight = maxH + 'px'; });
    });

    var firstRows = cards[0].querySelectorAll('.comparison-product__row');
    for (var i = 0; i < firstRows.length; i++) {
      (function (idx) {
        var rows = cards.map(function (c) {
          return c.querySelectorAll('.comparison-product__row')[idx];
        }).filter(Boolean);
        var maxH = Math.max.apply(null, rows.map(function (r) {
          return r.getBoundingClientRect().height;
        }));
        rows.forEach(function (r) { r.style.minHeight = maxH + 'px'; });
      })(i);
    }
  }

  function initEqualize() {
    var imgs = Array.prototype.slice.call(sectionEl.querySelectorAll('img'));
    var pending = imgs.filter(function (img) { return !img.complete; }).length;
    if (pending === 0) { equalizeGrid(); return; }
    imgs.forEach(function (img) {
      if (!img.complete) {
        var done = function () { pending--; if (pending === 0) equalizeGrid(); };
        img.addEventListener('load', done, { once: true });
        img.addEventListener('error', done, { once: true });
      }
    });
    equalizeGrid();
    setTimeout(equalizeGrid, 600);
  }

  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () { resetHeights(); equalizeGrid(); }, 200);
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEqualize);
  } else {
    initEqualize();
  }
})();
</script>

{% schema %}
{
  "name": "Comparison product",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "container", "label": "Contained" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "container"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Description",
      "default": "Compare our products side by side"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Title",
      "default": "Compare Products"
    },
    {
      "type": "select",
      "id": "heading_position",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "bottom",
      "label": "Heading position"
    },
    {
      "type": "select",
      "id": "text_center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Desktop alignment"
    },
    {
      "type": "select",
      "id": "mobile_text_center",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Mobile alignment"
    },
    {
      "type": "header",
      "content": "View All button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "view_all_button_icon",
      "label": "Show arrow icon",
      "default": false
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Button label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "Link to comparison page"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "paragraph",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    },
  ],
  "blocks": [
    {
      "type": "product_column",
      "name": "Product Column",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "is_featured",
          "label": "Featured (highlighted card)",
          "default": false
        },
        {
          "type": "header",
          "content": "Default / placeholder content"
        },
        {
          "type": "text",
          "id": "default_title",
          "label": "Default title",
          "default": "Product Title"
        },
        {
          "type": "text",
          "id": "default_price",
          "label": "Default price",
          "default": "$99.99"
        },
        {
          "type": "image_picker",
          "id": "placeholder_image",
          "label": "Placeholder image"
        },
        {
          "type": "select",
          "id": "placeholder_style",
          "label": "Placeholder style (when no image)",
          "options": [
            { "value": "illustration", "label": "Illustration (SVG)" },
            { "value": "color", "label": "Solid color" }
          ],
          "default": "illustration"
        },
        {
          "type": "color",
          "id": "placeholder_color",
          "label": "Placeholder color",
          "default": "#e8e8e8",
          "visible_if": "{{ block.settings.placeholder_style == 'color' }}"
        },
        {
          "type": "header",
          "content": "Buttons"
        },
        {
          "type": "text",
          "id": "buy_now_label",
          "label": "Buy now button label",
          "default": "Buy Now"
        },
        {
          "type": "text",
          "id": "quick_add_label",
          "label": "Quick add button label",
          "default": "+ Quick Add"
        },
        {
          "type": "header",
          "content": "Help link"
        },
        {
          "type": "text",
          "id": "help_text",
          "label": "Help text",
          "default": "Need help?"
        },
        {
          "type": "text",
          "id": "help_phone",
          "label": "Phone number",
          "default": "+1 800 000 0000"
        },
        {
          "type": "text",
          "id": "help_phone_href",
          "label": "Phone href",
          "default": "+18000000000"
        }
      ]
    },
    {
      "type": "comparison_row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "select",
          "id": "row_type",
          "label": "Row type",
          "options": [
            { "value": "vendor", "label": "Vendor / Brand" },
            { "value": "availability", "label": "Availability" },
            { "value": "product_type", "label": "Product Type" },
            { "value": "options", "label": "Product Options" },
            { "value": "description", "label": "Description" },
            { "value": "rating", "label": "Product Rating" },
            { "value": "variant_count", "label": "Variant Count" },
            { "value": "metafield", "label": "Metafield" },
            { "value": "custom", "label": "Custom text" }
          ],
          "default": "availability"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Row label",
          "info": "Shown in the label column. If blank, the row type name is used."
        },
        {
          "type": "text",
          "id": "metafield_key",
          "label": "Metafield key (namespace.key)",
          "info": "Required when Row type is Metafield",
          "visible_if": "{{ block.settings.row_type == 'metafield' }}"
        },
        {
          "type": "text",
          "id": "custom_value",
          "label": "Custom value (same for all columns)",
          "visible_if": "{{ block.settings.row_type == 'custom' }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison product",
      "blocks": [
        {
          "type": "comparison_row",
          "settings": { "row_type": "vendor", "label": "Brand" }
        },
        {
          "type": "comparison_row",
          "settings": { "row_type": "availability", "label": "Availability" }
        },
        {
          "type": "comparison_row",
          "settings": { "row_type": "product_type", "label": "Type" }
        },
        {
          "type": "comparison_row",
          "settings": { "row_type": "options", "label": "Available Options" }
        },
        {
          "type": "comparison_row",
          "settings": { "row_type": "rating", "label": "Rating" }
        },
        {
          "type": "product_column",
          "settings": { "default_title": "Product Title", "default_price": "$99.99" }
        },
        {
          "type": "product_column",
          "settings": { "default_title": "Product Title", "default_price": "$99.99", "is_featured": true }
        },
        {
          "type": "product_column",
          "settings": { "default_title": "Product Title", "default_price": "$99.99" }
        }
      ]
    }
  ]
}
{% endschema %}

