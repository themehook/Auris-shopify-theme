        {
          "value": "style_2",
          "label": "Style 2"
        },
        {
          "value": "style_3",
          "label": "Style 3"
        }
      ],
      "default": "style_1"
    },
    {
      "type": "select",
      "id": "card_content_align",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.hooktheme-collection-product-grid.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.hooktheme-collection-product-grid.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.hooktheme-collection-product-grid.settings.image_ratio.options__3.label"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ],
      "default": "adapt",
      "label": "t:sections.hooktheme-collection-product-grid.settings.image_ratio.label"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "t:sections.hooktheme-collection-product-grid.settings.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "color_swatches",
      "default": true,
      "label": "Enable color swatches",
      "info": "To display color swatches, you need to enable it. [Learn more](https://themihub.gitbook.io/suruchi-theme/theme-settings/color-swatches)."
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "default": true,
      "label": "Show badges"
    },
    {
      "type": "checkbox",
      "id": "show_quick_view_button",
      "default": true,
      "label": "Show quick view"
    },
    {
      "type": "checkbox",
      "id": "show_compare_view_button",
      "default": true,
      "label": "Show compare button"
    },
    {
      "type": "checkbox",
      "id": "show_wishlist_button",
      "default": true,
      "label": "Show wishlist button"
    },
    {
      "type": "checkbox",
      "id": "show_select_button",
      "default": true,
      "label": "Show select button"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "default": "secondary",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.buttons.settings.solid_button.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.buttons.settings.outline_button.label"
        },
        {
          "value": "icon",
          "label": "t:sections.all.buttons.settings.link_button.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "default": true,
      "label": "Show title"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "default": true,
      "label": "Show price"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.hooktheme-collection-product-grid.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_product_rating",
      "default": false,
      "label": "Show product rating"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "default": false,
      "label": "Show countdown",
      "info": "Follow the instructions on how to add a countdown timer to a product. [click here](https://gloryio.com/doc/taddy-product-countdown/)"
