    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Label",
      "default": "Message"
    },
    {
      "type": "text",
      "id": "message_placeholder",
      "label": "Placeholder",
      "default": "Allergies, high chair needed, etc"
    },
    {
