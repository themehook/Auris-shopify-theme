{% liquid
  assign is_rtl_theme = false
  if settings.use_rtl and settings.rtl_languages == blank
    assign is_rtl_theme = true
  endif

  if settings.use_rtl and settings.rtl_languages != blank
    assign rtl_langs = settings.rtl_languages | split: ','
    for lang in rtl_langs
      if lang == request.locale.iso_code
        assign is_rtl_theme = true
      endif
    endfor
  endif
%}

{{ 'hooktheme-grid.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-mobile-scrolling.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-slider-pagination.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-slider-navigation.css' | asset_url | stylesheet_tag }}
{{ 'section-title.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}

{% if is_rtl_theme %}
  {{ 'hooktheme-slider-navigation-rtl.css' | asset_url | stylesheet_tag }}
  {{ 'section-featured-blog-rtl.css' | asset_url | stylesheet_tag }}
{% endif %}
{%- style -%}
   .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
     --padding-top: {{ section.settings.mobile_padding_top }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      --padding-top: {{ section.settings.padding_top }}px;
    }
  }
   #MainContent > :first-child .section--top-space-{{ section.id }} {
     margin-top: calc(var(--header-height) * var(--transparent-header-show));
   }
{%- endstyle -%}

{%- liquid
  assign container = ''
  if section.settings.container == 'container'
    assign container = 'container'
  elsif section.settings.container == 'container-fluid'
    assign container = 'container-fluid'
  else
    assign container = 'container-fluid px-0'
  endif

  assign desktop_column = section.settings.card_column_on_desktop
  assign tablet_column = 2
  assign mobile_column = section.settings.card_column_on_mobile
  assign slide_autoplay = section.settings.auto_rotate
  assign autoplay_time = section.settings.change_slides_speed

  assign grid = 'grid'
  if section.settings.layout == 'collage'
    assign grid = 'blog--collage'
  endif

  assign carousel_enable = false
  if section.settings.layout == 'slider'
    assign carousel_enable = true
  endif

  assign grid_item = ''
  if section.settings.layout == 'grid'
    assign grid_item = 'grid__item'
  elsif section.settings.layout == 'collage'
    assign grid_item = 'blog_collage__item'
  elsif section.settings.layout == 'slider'
    assign grid_item = 'swiper-slide'
  endif

  assign article_count = section.settings.post_limit
  if section.settings.blog and section.settings.blog.articles_count > 0
    if section.settings.post_limit > section.settings.blog.articles_count
      assign article_count = section.settings.blog.articles_count
    endif
  endif

  assign collage_itme_thumbnail_width_count = article_count | minus: 1

  if article_count == 2
    assign collage_itme_thumbnail_width_count = 2
  endif

  if section.settings.button_type == 'primary'
    assign button_class = 'button--primary'
  elsif section.settings.button_type == 'link'
    assign button_class = 'link with--icon button--not-underline link--button-xl-font'
  else
    assign button_class = 'button--secondary'
  endif

  assign view_all_button = false
  if section.settings.show_view_all and section.settings.post_limit < section.settings.blog.articles_count
    assign view_all_button = true
  endif

  assign product_desktop_column = section.settings.card_column_on_desktop | times: 1
  assign product_mobile_column = section.settings.card_column_on_mobile | times: 1
  assign desktop_loop = false
  assign tablet_loop = false
  assign mobile_loop = false
  if section.settings.blog.articles_count > product_desktop_column and section.settings.post_limit > product_desktop_column
    assign desktop_loop = true
  endif
  if section.settings.blog.articles_count > 2 and section.settings.post_limit > 2
    assign tablet_loop = true
  endif

  if section.settings.blog.articles_count > product_mobile_column and section.settings.post_limit > product_mobile_column
    assign mobile_loop = true
  endif

  if section.settings.blog == blank or section.settings.blog.articles_count == 0
    assign desktop_loop = true
    assign tablet_loop = true
    assign mobile_loop = true
  endif
-%}

{%- capture container_class -%}
{%- if carousel_enable -%}
    blog-slider--wrapper component--slider-wrapper hero__slider--activation swiper  
{%- else -%}
{{ grid }} {% if section.settings.layout == "collage" %} blog--collage-{{ article_count }}{% endif %} {% if section.settings.layout == "grid" %} grid--{{ desktop_column }}-col-desktop grid--{{ mobile_column }}-col-tablet-down {% endif %}
{%- endif -%}
{%- endcapture -%}

<div class="blog__section section--padding section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} section--top-space-{{ section.id }}">
  {%- if carousel_enable -%}
    <slideshow-component
      data-section-id="{{ section.id }}"
      data-section-type="slideShow"
      data-slidesperview="{{ desktop_column }}"
      data-samlldesktopview="{{ desktop_column }}"
      data-show-tablet="{{ tablet_column }}"
      data-show-mobile="{{ mobile_column }}"
      data-slider-autoplay="{{ slide_autoplay }}"
      data-autoplay-time="{{ autoplay_time }}000"
      data-slider-loop="{{ desktop_loop }}"
      data-slider-loop-tablet="{{ tablet_loop }}"
      data-slider-loop-mobile="{{ mobile_loop }}"
      data-slider-space-betweeen="20"
      data-slideshow="20"
    >
  {%- endif -%}
  <div class="{{ container }} {% unless section.settings.show_offset %}p-0{% endunless %}">
    {% if section.settings.button_position == 'top' and view_all_button %}
      <div class="section--header-wrapper mb-50">
    {% endif %}
    <div class="section-heading text-{{ section.settings.text_center }} mobile-text-{{ section.settings.mobile_text_center }} {% if section.settings.heading != blank or section.settings.description != blank %} {% if section.settings.button_position != 'top' %} mb-50 {% endif %} {% endif %} {% if section.settings.button_position == 'top' and view_all_button == false %}mb-50{% endif %}  {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {% if section.settings.heading_position == 'bottom' and section.settings.description != blank %}
        <div class="section-heading__sub_title {{ section.settings.description_style }} rte">
          {{ section.settings.description -}}
        </div>
      {% endif %}
      <h2 class="section-heading__title {{ section.settings.heading_size }}">
        {{- section.settings.heading -}}
      </h2>
      {% if section.settings.heading_position == 'top' and section.settings.description != blank %}
        <div class="section-heading__sub_title {{ section.settings.description_style }} rte">
          {{ section.settings.description -}}
        </div>
      {% endif %}
    </div>

    {%- if section.settings.button_position == 'top' and view_all_button -%}
      <div class="button--wrapper mobile-text-{{ section.settings.mobile_text_center }}">
        <a
          href="{{ section.settings.blog.url }}"
          class="{% unless section.settings.button_type == 'link' %}button button--{{ section.settings.button_size }} {% endunless %} {{ button_class }} {% if section.settings.button_icon %} button--with-icon{% endif %}"
        >
          {{ 'sections.featured_blog.view_all' | t }}

          {% if section.settings.button_icon %}
            <span class="button--icon button--icon-right">
              {% if section.settings.icon_type == 'arrow' %}
                {% render 'hooktheme-icon-arrow-right' %}
              {% elsif section.settings.icon_type == 'chevron' %}
                {% render 'hooktheme-icon-chevron-right' %}
              {% elsif section.settings.icon_type == 'chevron_double' %}
                {% render 'hooktheme-icon-double-chevron-right' %}
              {% endif %}
            </span>
          {% endif %}
        </a>
      </div>
    {%- endif -%}
    {% if section.settings.button_position == 'top' and view_all_button %}
      </div>
    {% endif %}

    {% if section.settings.mobile_stack == false and section.settings.layout != 'slider' %}
      <div class="mobile--horizontal-slider">
        <div class="mobile--horizontal-slider-inner">
    {% endif %}

    <div
      class="blog__section--inner {{ container_class }} {% if section.settings.mobile_stack and section.settings.layout == 'collage' %}blog--items-gap-mobile{% endif %} {% if settings.animations_reveal_on_scroll  and carousel_enable %} scroll-trigger animate--slide-in{% endif %}"
      {% if section.settings.layout == 'collage' %}
        style="--collage-rows: repeat({{ article_count | minus: 1 }}, 1fr); --collage-grid-firs-col-rows: span {% if article_count == 2 %}{{ article_count }}{% else %}{{ article_count | minus: 1 }}{% endif %}; --collage-item-thumbnail-width: 0 0 {{ 100 | divided_by: collage_itme_thumbnail_width_count }}%;"
      {% endif %}
    >
      {%- if carousel_enable -%}<div class="swiper-wrapper">{%- endif -%}

      {%- if section.settings.blog != blank and section.settings.blog.articles_count > 0 -%}
        {%- for article in section.settings.blog.articles limit: section.settings.post_limit -%}
          <div
            class="blog--post-item {{ grid_item }}  {% if settings.animations_reveal_on_scroll  and carousel_enable == false %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll and carousel_enable == false %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {% render 'article-card',
              show_content: section.settings.show_content,
              blog: section.settings.blog,
              article: article,
              show_image: section.settings.show_image,
              show_date: section.settings.show_date,
              show_author: section.settings.show_author,
              show_comment: section.settings.show_comment,
              button_type: section.settings.read_more_btn_type,
              color_scheme: section.settings.card_color_scheme,
              corner_radius: section.settings.card_corner_radius,
              layout: section.settings.layout,
              articles_count: section.settings.blog.articles_count,
              article_index: forloop.index,
              image_ratio: section.settings.image_ratio,
              grid_column: section.settings.card_column_on_desktop,
              mobile_grid_column: section.settings.card_column_on_mobile,
              article_heading_size: section.settings.article_heading_size,
              content_limit: section.settings.content_limit
            %}
          </div>
        {%- endfor -%}

      {%- else -%}
        {% for i in (1..section.settings.post_limit) %}
          {%- assign placeholder_image_index = forloop.index0 | modulo: 3 | plus: 1 -%}
          {%- assign placeholder_image = 'blog-apparel-' | append: placeholder_image_index -%}
          <div class="blog--post-item {{ grid_item }}">
            <article
              class="article--card article--{{ section.settings.layout }} {% if section.settings.card_corner_radius %}article--card-radius{% endif %}"
              aria-labelledby="Article-{{ article.id }}"
            >
              <div class="blog__items--thumbnail card--client-height">
                <div class="article-card__image placeholder">
                  {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg-new' }}
                </div>
              </div>
              <div class="blog__items--content">
                <h3 class="article-card__title h4 mb-0">
                  {{ 'sections.featured_blog.onboarding_title' | t }}
                </h3>
                <p class="blog__items--desc">{{ 'sections.featured_blog.onboarding_content' | t }}</p>
              </div>
            </article>
          </div>
        {% endfor %}
      {%- endif -%}

      {%- if carousel_enable -%}
        </div>
      {%- endif -%}

      {%- if carousel_enable -%}
        {%- if section.settings.show_navigation -%}
          <div class="swiper-button-prev  component--slider--nav color-{{ section.settings.color_scheme_navigation }}">
            {% render 'hooktheme-icon-chevron-left' %}
          </div>
          <div class="swiper-button-next component--slider--nav  color-{{ section.settings.color_scheme_navigation }}">
            {% render 'hooktheme-icon-chevron-right' %}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>

    {% if section.settings.mobile_stack == false and section.settings.layout != 'slider' %}
      </div>
      </div>
    {% endif %}

    {% if section.settings.button_position == 'bottom' %}
      {%- if section.settings.show_view_all and section.settings.post_limit < section.settings.blog.articles_count -%}
        <div class="blog__view-all center mt-40">
          <a
            href="{{ section.settings.blog.url }}"
            class="{% unless section.settings.button_type == 'link' %}button button--{{ section.settings.button_size }} {% endunless %} {{ button_class }} {% if section.settings.button_icon %} button--with-icon{% endif %}"
          >
            {{ 'sections.featured_blog.view_all' | t }}

            {% if section.settings.button_icon %}
              <span class="button--icon button--icon-right">
                {% if section.settings.icon_type == 'arrow' %}
                  {% render 'hooktheme-icon-arrow-right' %}
                {% elsif section.settings.icon_type == 'chevron' %}
                  {% render 'hooktheme-icon-chevron-right' %}
                {% elsif section.settings.icon_type == 'chevron_double' %}
                  {% render 'hooktheme-icon-double-chevron-right' %}
                {% endif %}
              </span>
            {% endif %}
          </a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
  {%- if carousel_enable -%}</slideshow-component>{%- endif -%}
</div>

