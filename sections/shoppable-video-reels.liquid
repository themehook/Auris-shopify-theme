{{ 'hooktheme-video-reels.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-slider-pagination.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-slider-navigation.css' | asset_url | stylesheet_tag }}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.5 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #section__{{ section.id }} {
    --slider-button-background: {{ section.settings.button_background }};
    --slider-button-color: {{ section.settings.button_text_color }};
  }

  {%- if section.settings.custom_colors_navigation -%}
    #section__{{ section.id }} {
      --color-foreground: {{ section.settings.nav_foreground.red }}, {{ section.settings.nav_foreground.green }}, {{ section.settings.nav_foreground.blue }};
      --color-background: {{ section.settings.nav_background.red }}, {{ section.settings.nav_background.green }}, {{ section.settings.nav_background.blue }};
    }
  {%- endif -%}
    #MainContent > :first-child .section--top-space-{{ section.id }} {
     margin-top: calc(var(--header-height) * var(--transparent-header-show));
   }
</style>

<script src="{{ 'hooktheme-video-reels.js' | asset_url }}" defer="defer"></script>


<div class="video-reels section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} section--top-space-{{ section.id }} {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}">
  <div class="video-reels__container-wrapper">
    {%- assign nav_in_header = false -%}
    {%- if section.settings.nav_position == 'header' and section.settings.show_navigation -%}
      {%- assign nav_in_header = true -%}
    {%- endif -%}
    {%- if section.settings.heading != blank or section.settings.kicker != blank -%}
      <div class="container">
      <div class="video-reels-header mb-20 {% if nav_in_header %}video-reels-header--with-nav{% endif %}">
        <div class="section-heading text-{{ section.settings.alignment }} mobile-text-{{ section.settings.mobile_alignment }}">
          {%- if section.settings.kicker != blank -%}
            <div class="video-reels-kicker" style="color: {{ section.settings.kicker_color }};">
              {%- if section.settings.show_kicker_shape -%}
                <span class="video-reels-kicker__shape" style="background-color: {{ section.settings.kicker_color }};"></span>
              {%- endif -%}
              <span class="video-reels-kicker__text">{{- section.settings.kicker -}}</span>
            </div>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="section-heading__title {{ section.settings.heading_size }} gradient--title">
              {{- section.settings.heading -}}
            </h2>
          {%- endif -%}
          {%- if section.settings.subtitle != blank -%}
            <div class="section-heading__sub_title">{{ section.settings.subtitle }}</div>
          {%- endif -%}
        </div>
        {%- if nav_in_header -%}
          <div class="video-reels__header-nav" id="section__{{ section.id }}">
            <button type="button" class="video-reels__nav-button video-reels__nav-button--prev">
              {% render 'hooktheme-icon-chevron-left' %}
            </button>
            <button type="button" class="video-reels__nav-button video-reels__nav-button--next">
              {% render 'hooktheme-icon-chevron-right' %}
            </button>
          </div>
        {%- endif -%}
      </div>
      </div>
    {%- endif -%}

    <video-reels-slider
      {% if section.settings.autoplay %}
        autoplay
      {% endif %}
    >
      <div class="video-reels__container swiper">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div
              class="swiper-slide video-reels__item{% if section.settings.round_corner %} video-reels__item--round{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="video-reels__media video-reels__media--{{ section.settings.media_ratio }}">
                <div class="video-reels__media-inner">
                  {%- if block.settings.video != blank -%}
                    {{
                      block.settings.video
                      | video_tag:
                        class: 'video-reels__video',                        
                        image_size: '500x',
                        loop: true,
                        muted: true,
                        playsinline: true,
                        preload: 'metadata'
                    }}
                    <!-- Video Controls Overlay -->
                    <div class="video-reels__controls-overlay">
                      <div class="video-reels__progress-bar">
                        <div class="video-reels__progress">
                          <span class="visually-hidden">{{ 'sections.video_reels.progress_bar' | t }}</span>
                        </div>
                      </div>
                      <div class="video-reels__controls">
                        <button
                          type="button"
                          class="video-reels__control-btn video-reels__play-btn"
                          aria-label="Play/Pause"
                          data-state="paused"
                        >
                          <span class="icon-play">{% render 'hooktheme-icon-play' %}</span>
                          <span class="icon-pause">{% render 'hooktheme-icon-pause' %}</span>
                        </button>
                        <button
                          type="button"
                          class="video-reels__control-btn video-reels__mute-btn"
                          aria-label="Mute/Unmute"
                          data-state="muted"
                        >
                          <span class="icon-volume">{% render 'hooktheme-icon-volume' %}</span>
                          <span class="icon-mute">{% render 'hooktheme-icon-mute' %}</span>
                        </button>
                      </div>
                    </div>

                  {%- else -%}
                    {%- capture placeholder_svg -%}
                        {% cycle 'product-apparel-1', 'product-apparel-2', 'product-apparel-3'  %} 
                      {%- endcapture -%}
                    <div class="video--reels-placeholder media">
                      {{ placeholder_svg | strip | placeholder_svg_tag: 'placeholder-svg-custom' }}
                    </div>
                  {%- endif -%}

                  {% render 'reels-product-card',
                    product_card: block.settings.product,
                    color_scheme: section.settings.video_card_color_scheme,
                    quick_shop_button_style: 'icon',
                    block: block,
                    section_id: section.id
                  %}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="video-reels__nav-buttons"{% unless nav_in_header %} id="section__{{ section.id }}"{% endunless %}>
          {%- unless nav_in_header -%}
            {%- if section.settings.show_navigation -%}
              <button type="button" class="video-reels__nav-button video-reels__nav-button--prev">
                {% render 'hooktheme-icon-chevron-left' %}
              </button>
              <button type="button" class="video-reels__nav-button video-reels__nav-button--next">
                {% render 'hooktheme-icon-chevron-right' %}
              </button>
            {%- endif -%}
          {%- endunless -%}
          {%- if section.settings.show_pagination -%}
            <div class="video-reels__pagination swiper-pagination component-slider--pagination"></div>
          {%- endif -%}
        </div>
      </div>
    </video-reels-slider>
  </div>
</div>

{% schema %}
{
  "name": "Video reels",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Subtitle",
      "info": "Short label displayed above the heading with a decorative shape"
    },
    {
      "type": "checkbox",
      "id": "show_kicker_shape",
      "label": "Show subtitle shape",
      "default": false
    },
    {
      "type": "color",
      "id": "kicker_color",
      "label": "Subtitle & shape color",
      "default": "#c5f000",
      "visible_if": "{{ section.settings.show_kicker_shape}}"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Video Reels"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "hxl2",
          "label": "Heading 3XL"
        },
        {
          "value": "hxl",
          "label": "Heading 2XL"
        },
        {
          "value": "h0",
          "label": "Heading XL"
        },
        {
          "value": "h1",
          "label": "Heading 1"
        },
        {
          "value": "h2",
          "label": "Heading 2"
        },
        {
          "value": "h3",
          "label": "Heading 3"
        },
        {
          "value": "h4",
          "label": "Heading 4"
        },
        {
          "value": "h5",
          "label": "Heading 5"
        },
        {
          "value": "h6",
          "label": "Heading 6"
        }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Desktop heading alignment"
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center",
      "label": "Mobile heading alignment"
    },
    {
      "type": "header",
      "content": "Video card"
    },
    {
      "type": "select",
      "id": "media_ratio",
      "options": [
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ],
      "default": "portrait",
      "label": "Video Aspect Ratio"
    },
    {
      "type": "checkbox",
      "id": "round_corner",
      "label": "Enable round corners",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay videos",
      "default": true,
      "info": "Videos will be muted when autoplay is enabled"
    },
    {
      "type": "color_scheme",
      "id": "video_card_color_scheme",
      "default": "background-1",
      "label": "t:sections.header.settings.color_scheme.label"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "select",
      "id": "nav_position",
      "label": "Navigation position",
      "options": [
        { "value": "slider", "label": "Middle" },
        { "value": "header", "label": " Top " }
      ],
      "default": "slider"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Navigation button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Navigation button color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "custom_colors_navigation",
      "label": "Use custom colors for navigation",
      "default": false
    },
    {
      "type": "color",
      "id": "nav_foreground",
      "label": "Navigation foreground color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "nav_background",
      "label": "Navigation background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video reels",
      "category": "Banners",
      "blocks": [
        {
          "type": "video"
        },
        {
          "type": "video"
        },
        {
          "type": "video"
        },
        {
          "type": "video"
        },
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}
