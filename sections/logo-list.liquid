{{ 'hooktheme-grid.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-mobile-scrolling.css' | asset_url | stylesheet_tag }}
{{ 'logo-list.css' | asset_url | stylesheet_tag }}
{{ 'hooktheme-slider-navigation.css' | asset_url | stylesheet_tag }}

{%- style -%}
    .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
        padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
      }

      @media screen and (min-width: 750px) {
        .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.padding_top }}px;
          padding-bottom: {{ section.settings.padding_bottom }}px;
        }
      }
    :root {
      --grid-desktop-vertical-spacing: 20px;
      --grid-desktop-horizontal-spacing: 20px;
      --grid-mobile-vertical-spacing: 20px;
      --grid-mobile-horizontal-spacing: 20px;
  }
   #MainContent > :first-child .section--top-space-{{ section.id }} {
     margin-top: calc(var(--header-height) * var(--transparent-header-show));
   }
{%- endstyle -%}

{%- liquid
  assign productShowXl = section.settings.products_show_on_xl
  assign productShowSm = section.settings.products_show_on_sm

  assign container = ''
  assign page_offset = false
  if section.settings.container == 'container'
    assign container = 'container'
  elsif section.settings.container == 'container-fluid'
    assign container = 'container-fluid'
    unless section.settings.show_offset
      assign page_offset = true
    endunless
  else
    assign container = 'container-fluid px-0'
  endif

  assign slider_enable = false
  if section.settings.layout == 'slider'
    assign slider_enable = true
  endif

  assign grid_item = ''
  if section.settings.layout == 'grid'
    assign grid_item = 'grid__item'
  elsif section.settings.layout == 'slider'
    assign grid_item = 'swiper-slide'
  endif
-%}

{%- capture container_class -%}
{%- if slider_enable -%}
logo--list__slider hero__slider--activation swiper
{%- else -%}
grid grid--{{ productShowXl }}-col-desktop grid--{{ productShowSm }}-col-tablet-down
{%- endif -%}
{%- endcapture -%}

<div
  class="brand__logo--section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} section--top-space-{{ section.id }} {% if section.settings.border_top %}logo--list-border-top{% endif %} {% if section.settings.border_bottom %}logo--list-border-bottom{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="slideShow"
  id="slideshow__{{ section.id }}"
  {%- if slider_enable -%}
    data-slide-autoplay="{{ section.settings.auto_rotate }}"
    data-autoplay-duration="{{ section.settings.change_slides_speed }}000"
    data-slide-loop="true"
    data-slideshow="20"
    data-slidesperview="{{ productShowXl }}"
    data-samlldesktopview="{{ productShowXl }}"
    data-show-tablet="{{ productShowSm }}"
    data-show-mobile="{{ productShowSm }}"
  {% endif %}
>
  <div class="{{ container }} {% if page_offset %}p-0{% endif %}">
    {% if section.settings.mobile_stack == false and section.settings.layout != 'slider' %}
      <div class="mobile--scoller">
        <div class="mobile--scoller-inner logo--list-inner">
    {% endif %}
    <div class="brand__logo--section__inner {{ section.settings.logo_alignment }} {{ container_class }} {% if section.settings.logo_center and section.settings.layout != 'slider' %} brand-logo-centered {% endif %}">
      {%- if slider_enable -%}<div class="swiper-wrapper">{% endif %}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'logo' -%}
            <div
              class="logo--list-item {{ grid_item }}  {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              <div
                class="brand__logo--items {% if block.settings.logo == blank %}placeholder-logo{% endif %} {% if section.settings.round_corner %}rounder-corner-image{% endif %}"
                style="--logo-width: {{ section.settings.logo_width }}px;"
              >
                {% if block.settings.url != blank %}
                  <a
                    href="{{ block.settings.url }}"
                    class="d-block"
                    aria-label="{{ block.settings.logo.alt | default: shop.name | escape }}"
                  >
                {% endif %}
                {%- if block.settings.logo != blank -%}
                  {%- assign logo_alt = block.settings.logo.alt | default: shop.name | escape -%}
                  {%- assign logo_height = section.settings.logo_width
                    | divided_by: block.settings.logo.aspect_ratio
                  -%}
                  {% capture sizes %}(max-width: {{ section.settings.logo_width | times: 2 }}px) 50vw, {{ section.settings.logo_width }}px{% endcapture %}
                  {% capture widths %}{{ section.settings.logo_width }}, {{ section.settings.logo_width | times: 1.5 | round }}, {{ section.settings.logo_width | times: 2 }}{% endcapture %}
                  {{
                    block.settings.logo
                    | image_url: width: 600
                    | image_tag:
                      class: 'brand__logo--items__thumbnail--img',
                      widths: widths,
                      height: logo_height,
                      width: section.settings.logo_width,
                      alt: logo_alt,
                      sizes: sizes,
                      preload: true
                  }}
                {%- else -%}
                  {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg-new' }}
                {%- endif -%}
                {% if block.settings.url != blank %} </a>{% endif %}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
      {%- if slider_enable -%}</div>{% endif %}
      {%- if slider_enable and section.settings.show_navigation -%}
        <div class="swiper__nav--btn swiper-button-prev  component--slider--nav color-{{ section.settings.color_scheme_navigation }}">
          {% render 'hooktheme-icon-arrow-left' %}
        </div>
        <div class="swiper__nav--btn swiper-button-next component--slider--nav color-{{ section.settings.color_scheme_navigation }}">
          {% render 'hooktheme-icon-arrow-right' %}
        </div>
      {%- endif -%}
    </div>

    {% if section.settings.mobile_stack == false and section.settings.layout != 'slider' %}
      </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Logo list",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Page width",
      "default": "container",
      "info": "It will affect on the larger screen",
      "options": [
        {
          "value": "container",
          "label": "Boxed"
        },
        {
          "value": "container-fluid",
          "label": "Full width"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_offset",
      "label": "Enable horizontal space",
      "default": true,
      "info": "It will work if you select the \"Full width\" of the page width"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 250,
      "step": 10,
      "default": 150,
      "unit": "t:sections.header.settings.logo_width.unit",
      "label": "t:sections.header.settings.logo_width.label"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "slider",
          "label": "Slider"
        }
      ],
      "default": "slider",
      "label": "Desktop layout"
    },
    {
      "type": "select",
      "id": "products_show_on_xl",
      "label": "Number of columns on desktop",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        },
        {
          "value": "6",
          "label": "6"
        }
      ],
      "default": "6"
    },
    {
      "type": "select",
      "id": "products_show_on_sm",
      "label": "Number of columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "logo_alignment",
      "options": [
        {
          "value": "justify-content-start",
          "label": "Left"
        },
        {
          "value": "justify-content-center",
          "label": "Center"
        },
        {
          "value": "justify-content-end",
          "label": "Right"
        }
      ],
      "default": "justify-content-start",
      "label": "Desktop alignment"
    },
    {
      "type": "checkbox",
      "id": "logo_center",
      "label": "Logo centered",
      "default": false,
      "visible_if": "{{ section.settings.layout == 'grid' }}"
    },
    {
      "type": "checkbox",
      "id": "mobile_stack",
      "label": "Stack on mobile",
      "default": false,
      "info": "This is only applicable to the Grid layout."
    },
    {
      "type": "checkbox",
      "id": "border_top",
      "label": "Enable border top",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "border_bottom",
      "label": "Enable border bottom",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "round_corner",
      "label": "Round corner",
      "default": true
    },
    {
      "type": "header",
      "content": "Slider settings",
      "visible_if": "{{ section.settings.layout == 'slider' }}"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false,
      "visible_if": "{{ section.settings.layout == 'slider' }}"
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 2,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 3,
      "visible_if": "{{ section.settings.layout == 'slider' }}"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation",
      "default": false,
      "visible_if": "{{ section.settings.layout == 'slider' }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme_navigation",
      "label": "Navigation colors",
      "default": "accent-1",
      "visible_if": "{{ section.settings.layout == 'slider' }}"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "paragraph",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-2"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Logo link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo list",
      "category": "Storytelling",
      "blocks": [
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        },
        {
          "type": "logo"
        }
      ]
    }
  ]
}
{% endschema %}
