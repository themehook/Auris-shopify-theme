{%- liquid
  assign theme_rtl = false
  if settings.enable_rtl and settings.langauges_rtl == blank
    assign theme_rtl = true
  endif

  if settings.enable_rtl and settings.langauges_rtl != blank
    assign rtl_languages = settings.langauges_rtl | split: ','
    for language in rtl_languages
      if language == request.locale.iso_code
        assign theme_rtl = true
      endif
    endfor
  endif
-%}

{{ 'image-with-columns.css' | asset_url | stylesheet_tag }}

{%- liquid

  assign container = ''
  assign page_offset = false
  if section.settings.container == 'container'
    assign container = 'container'
  elsif section.settings.container == 'container-fluid'
    assign container = 'container-fluid'
    unless section.settings.show_offset
      assign page_offset = true
    endunless
  else
    assign container = 'container-fluid px-0'
  endif

-%}

{%- style -%}

 .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
     --padding-top: {{ section.settings.mobile_padding_top }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      --padding-top: {{ section.settings.padding_top }}px;
    }
  }

   .image-with-columns-{{ section.id }}.image-with-columns-bg-media.media::before {
    opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
  }

  {%- if section.settings.image_position == 'image_bottom' -%}
    #iwc-wrapper-{{ section.id }} .image-with-columns-thumbnail { order: 3; }
    #iwc-wrapper-{{ section.id }} .columns-text-wrapper { order: 1; }
    #iwc-wrapper-{{ section.id }} .iwc-button-wrap { order: 2; }
  {%- else -%}
    #iwc-wrapper-{{ section.id }} .image-with-columns-thumbnail { order: 1; }
    #iwc-wrapper-{{ section.id }} .columns-text-wrapper { order: 2; }
    #iwc-wrapper-{{ section.id }} .iwc-button-wrap { order: 3; }
  {%- endif -%}

  #iwc-wrapper-{{ section.id }} .iwc-columns-grid {
    --iwc-columns: {{ section.settings.columns_per_row }};
    --iwc-gap: {{ section.settings.column_gap }}px;
  }

{%- endstyle -%}

<div class="image-with-columns-section image-with-columns-{{ section.id }} color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
>
  {%- if section.settings.image_2 != blank -%}
    <div class="image-with-columns-{{ section.id }} image-with-columns-bg-media media">
      <img
        srcset="
          {%- if section.settings.image_2.width >= 375 -%}{{ section.settings.image_2 | image_url: width: 375 }} 375w,{%- endif -%}
          {%- if section.settings.image_2.width >= 550 -%}{{ section.settings.image_2 | image_url: width: 550 }} 550w,{%- endif -%}
          {%- if section.settings.image_2.width >= 750 -%}{{ section.settings.image_2 | image_url: width: 750 }} 750w,{%- endif -%}
          {%- if section.settings.image_2.width >= 1100 -%}{{ section.settings.image_2 | image_url: width: 1100 }} 1100w,{%- endif -%}
          {%- if section.settings.image_2.width >= 1500 -%}{{ section.settings.image_2 | image_url: width: 1500 }} 1500w,{%- endif -%}
          {%- if section.settings.image_2.width >= 1780 -%}{{ section.settings.image_2 | image_url: width: 1780 }} 1780w,{%- endif -%}
          {%- if section.settings.image_2.width >= 2000 -%}{{ section.settings.image_2 | image_url: width: 2000 }} 2000w,{%- endif -%}
          {%- if section.settings.image_2.width >= 3000 -%}{{ section.settings.image_2 | image_url: width: 3000 }} 3000w,{%- endif -%}
          {%- if section.settings.image_2.width >= 3840 -%}{{ section.settings.image_2 | image_url: width: 3840 }} 3840w,{%- endif -%}
          {{ section.settings.image_2 | image_url }} {{ section.settings.image_2.width }}w
        "
        sizes="100vw"
        src="{{ section.settings.image_2 | image_url: width: 1500 }}"
        loading="lazy"
        alt="{{ section.settings.image_2.alt | escape }}"
        width="{{ section.settings.image_2.width }}"
        height="{{ section.settings.image_2.width | divided_by: section.settings.image_2.aspect_ratio }}"
      >
    </div>
  {%- endif -%}
  <div class="{{ container }} {% if page_offset %}p-0{% endif %}">
    {%- if section.settings.subtitle != blank or section.settings.heading != blank or section.settings.description != blank -%}
      <div class="iwc-section-heading text-{{ section.settings.heading_alignment }}">
        {%- if section.settings.subtitle != blank -%}
          <span class="iwc-subtitle">{{- section.settings.subtitle -}}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="iwc-title gradient--text {{ section.settings.heading_size }}">
            {{- section.settings.heading | replace: 'p>', 'span>' | replace: 'h1>', 'span>' | replace: 'h2>', 'span>' | replace: 'h3>', 'span>' -}}
          </h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="iwc-description rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div id="iwc-wrapper-{{ section.id }}" class="image-with-columns-wrapper {{ section.settings.image_position }}  {% if section.settings.image_2 != blank %} columns-wrapper-relative {% endif %}">
        <!-- Image Section -->
        <div class="image-with-columns-thumbnail image-width--{{ section.settings.image_width }}">
          <div class="image-columns-media image-columns-media--{{ section.settings.height }} {% if section.settings.image_1 != blank %}media{% else %}image-with-column-media--placeholder placeholder{% endif %} {% if section.settings.round_corner %} rounded--image {% endif %}  {% if section.settings.bg_transparent %} media-transparent {% endif %}"
              {% if section.settings.image_1 != blank and section.settings.height == 'adapt'  %}       
                  style="padding-bottom: {{ 1 | divided_by: section.settings.image_1.aspect_ratio | times: 100 }}%;"
              {% endif %}
              >
              {% if section.settings.image_1 != blank %}
              {%- assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840' -%}
                  {%- capture sizes -%}
                  (min-width: {{ settings.container_lg_width }}px) {{ settings.container_lg_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc((100vw - 130px) / 2), 100vw
                  {%- endcapture -%}
              
              {{
                  section.settings.image_1
                  | image_url: width: 1920
                  | image_tag:
                  loading: 'lazy',
                  sizes: sizes,
                  widths: widths ,
                  class: 'hero-image'
              }}
              {% else %}
              {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg-new' }}
              {% endif %}
          </div>
        </div>
        
        <!-- Columns Section -->
        {% if section.blocks.size > 0 %}
          <div class="columns-text-wrapper">
              <div class="iwc-columns-grid">
              {%- for block in section.blocks -%}
                  {%- case block.type -%}
                  {%- when 'column' -%}
                      <div {{ block.shopify_attributes }}>
                      <div class="columns--item color-{{ section.settings.color_scheme_2 }} h-100 text-{{ section.settings.text_alignment }} {% if section.settings.show_border %} columns-item-border {% endif %}{% if block.settings.show_icon %} columns--item-icon-{{ block.settings.icon_position }}{% endif %}">
                          {%- if block.settings.show_icon -%}
                            <div class="columns--icon-wrap">
                              {%- if block.settings.icon != blank -%}
                                <img
                                  src="{{ block.settings.icon | image_url: width: 200 }}"
                                  alt="{{ block.settings.icon.alt | escape }}"
                                  width="{{ block.settings.icon_width }}"
                                  height="{{ block.settings.icon_width }}"
                                  loading="lazy"
                                  style="width: {{ block.settings.icon_width }}px; height: {{ block.settings.icon_width }}px;"
                                >
                              {%- else -%}
                                <svg xmlns="http://www.w3.org/2000/svg" width="{{ block.settings.icon_width }}" height="{{ block.settings.icon_width }}" viewBox="0 0 48 48" fill="none" class="columns--icon-placeholder" aria-hidden="true">
                                  <rect width="48" height="48" rx="12" fill="rgba(var(--color-button), 0.12)"/>
                                  <path d="M24 10l4.5 9 10 1.5-7.25 7 1.75 10-9-4.75-9 4.75 1.75-10L9.5 20.5l10-1.5z" fill="rgb(var(--color-button))"/>
                                </svg>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                          <div class="columns--body">
                            {% if block.settings.title != blank %}
                            <h3 class="columns--title gradient--text {{ block.settings.heading_size }} mb-20">
                                {{- block.settings.title | replace: 'p>', 'span>' | replace: 'h1>', 'span>' | replace: 'h2>', 'span>' | replace: 'h3>', 'span>' | replace: 'h4>', 'span>' -}}
                            </h3>
                            {% endif %}

                            {% if block.settings.text != blank %}
                            <div class="columns--text">
                                {{ block.settings.text }}
                            </div>
                            {% endif %}
                          </div>
                      </div>
                      </div>
                  {%- endcase -%}
              {%- endfor -%}
              </div>
          </div>
        {% endif %}
        {%- if section.settings.show_button and section.settings.button_label != blank -%}
          <div class="iwc-button-wrap text-{{ section.settings.heading_alignment }}">
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="button button--{{ section.settings.button_style }} button--{{ section.settings.button_size }}"
            >
              {{- section.settings.button_label | escape -}}
            </a>
          </div>
        {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with columns",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Page width",
      "default": "container",
      "options": [
        {
          "value": "container",
          "label": "Boxed"
