{% liquid
  assign theme_rtl = false
  if settings.enable_rtl and settings.langauges_rtl == blank
    assign theme_rtl = true
  endif

  if settings.enable_rtl and settings.langauges_rtl != blank
    assign rtl_languages = settings.langauges_rtl | split: ','
    for language in rtl_languages
      if language == request.locale.iso_code
        assign theme_rtl = true
      endif
    endfor
  endif
%}

<link rel="stylesheet" href="{{ 'hooktheme-rte.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'hooktheme-rte.css' | asset_url | stylesheet_tag }}</noscript>

{{ 'button-panel.css' | asset_url | stylesheet_tag }}


<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #MainContent > :first-child .section--top-space-{{ section.id }} {
     margin-top: calc(var(--header-height) * var(--transparent-header-show));
   }
</style>

{% if theme_rtl %}
  {{ 'featured-promotion-rtl.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- liquid
  assign container = ''
  if section.settings.container == 'container'
    assign container = 'container'
  elsif section.settings.container == 'container-fluid'
    assign container = 'container-fluid'
  else
    assign container = 'container-fluid px-0'
  endif


  assign slider_enable = section.settings.slider_enable


  
-%}
<div class="button__panel--section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} slideShow"
  data-section-id="{{ section.id }}" 
  data-section-type="slideShow"
  id="slideshow__{{ section.id }}"
>
  <div class="{{ container }}">
    <div class="section-heading desktop-text-{{ section.settings.text_center }} mobile-text-{{ section.settings.mobile_text_center }} {% if section.settings.heading != blank or section.settings.section_description != blank %} mb-50{% endif %}  {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {% if section.settings.heading_position == 'bottom' and section.settings.section_description != blank %}
        <div class="section-heading__sub_title {{ section.settings.description_style }} rte">
          {{ section.settings.section_description -}}
        </div>
      {% endif %}
      <h2 class="section-heading__title {{ section.settings.heading_size }}">
        {{- section.settings.heading -}}
      </h2>
      {% if section.settings.heading_position == 'top' and section.settings.section_description != blank %}
        <div class="section-heading__sub_title {{ section.settings.description_style }} rte">
          {{ section.settings.section_description -}}
        </div>
      {% endif %}
    </div>
      {% if section.settings.slider_enable %}
        <div class="button__panel--slider button_slider--activation swiper">
      {% endif %}

    
      <div
        class="button__panel--wrapper {% if section.settings.slider_enable %} swiper-wrapper {% else %} grid {% endif %} {{ section.settings.content_alignment }}"
        style="--icon-width: {{ section.settings.icon_width }}px;"
      >
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'button_block' -%}
              {% if section.settings.slider_enable %} <div class="button-panel-swiper-item swiper-slide"> {% endif %}
              <div
                class="button__panel--item "
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                
                <a
                    {% if block.settings.button_link == blank %}
                    role="link" aria-disabled="true"
                    {% else %}
                    href="{{ block.settings.button_link }}"
                    {% endif %}
                class="button__panel--item-link icon-{{ section.settings.icon_position }} {{ section.settings.button_style }} {% if section.settings.button_style == 'secondary_button' %} color-background-2 {% endif %} {% if section.settings.button_radius %} button-items-rounded {% endif %} color-{{ section.settings.button_color_scheme }}"
                >
                  
                <div class="button__panel--icon button-icon-width-{{ section.settings.icon_width }}">
                    {%- if block.settings.feature_image_icon != blank -%}
                        <span class="button-icon-field image--icon {{ section.settings.icon_image_width }}">
                        <img
                            src="{{ block.settings.feature_image_icon | image_url: width: 320, height: 320 }}"
                            alt="{{ block.settings.feature_image_icon.alt | escape }}"
                            width="320"
                            height="{{ 100 | divided_by: block.settings.feature_image_icon.aspect_ratio | ceil }}"
                            loading="lazy"
                        >
                        </span>
                    {% else %}

                        {%- render 'hooktheme-icon-featured-promotion',
                        icon: block.settings.icon,
                        icon_width: section.settings.icon_width
                        -%}
                    {%- endif -%}
                </div> 
                
                <span class="button__panel--name {{ section.settings.button_text_size }} ">{{- block.settings.button_label | escape }}</span>
                </a>
              </div>
              {% if section.settings.slider_enable %} </div> {% endif %}
          {%- endcase -%}
        {%- endfor -%}
      </div>
      {% if section.settings.slider_enable %}
        </div>
      {% endif %}
  </div>
</div>

<!-- Initialize Swiper -->
  <script>
    var swiper = new Swiper(".button_slider--activation", {
      slidesPerView: "auto",
      spaceBetween: 20,
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
    });
  </script>

