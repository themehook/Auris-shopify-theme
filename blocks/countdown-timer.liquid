{% stylesheet %}
  .countdown-block {
    display: flex;
    align-items: center;
  }

  .countdown-block__inner {
    display: flex;
    align-items: center;
  }

  .countdown-block .countdown__item {
    text-align: center;
  }

  .countdown-block .countdown__number {
    display: block;
  }

  .countdown-block .countdown__text {
    display: block;
  }

  /* --- Boxed style --- */
  .countdown-block--style-boxed .countdown__item {
    padding: 0.3rem 0.7rem;
    border-radius: 0.5rem;
    position: relative;
    border: 0.1rem solid rgba(var(--color-foreground), 0.19);
    min-width: 4.5rem;
  }

  .countdown-block--style-boxed .countdown__item + .countdown__item::before {
    position: absolute;
    content: ":";
    left: calc(var(--countdown-gap, 1rem) / -2);
    top: 50%;
    font-size: 3rem;
    transform: translate(-50%, -50%);
    color: rgba(var(--color-foreground));
  }

  .countdown-block--style-boxed .countdown__number {
    font-size: 1.6rem;
    line-height: 2.5rem;
  }

  .countdown-block--style-boxed .countdown__text {
    font-weight: 500;
    text-transform: uppercase;
    font-size: 1.3rem;
    line-height: 2rem;
  }

  .countdown-block--box-square .countdown__item {
    border-radius: 0;
  }

  @media screen and (min-width: 750px) {
    .countdown-block--style-boxed .countdown__item {
      padding: 0.5rem 0.8rem;
      min-width: 5rem;
    }
  }

  @media screen and (min-width: 992px) {
    .countdown-block--style-boxed .countdown__item {
      padding: 0.8rem 1rem;
      min-width: 8.5rem;
    }
    .countdown-block--style-boxed .countdown__number {
      font-size: 2.4rem;
    }
    .countdown-block--style-boxed .countdown__text {
      font-size: 1.5rem;
    }
  }

  @media screen and (min-width: 1200px) {
    .countdown-block--style-boxed .countdown__item {
      padding: 0.6rem 1.2rem;
      min-width: 8rem;
    }
    .countdown-block--style-boxed .countdown__number {
      font-size: 2.6rem;
    }
    .countdown-block--style-boxed .countdown__text {
      font-size: 1.6rem;
    }
  }

  /* --- Minimal style --- */
  .countdown-block--style-minimal .countdown__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .countdown-block--style-minimal .countdown__number {
    font-size: 2rem;
    position: relative;
  }

  .countdown-block--style-minimal .countdown__number::before {
    position: absolute;
    content: "";
    width: 100%;
    height: 0.1rem;
    background: rgba(var(--color-foreground), 0.3);
    inset-inline-start: 0;
    bottom: -0.25rem;
  }

  /* Label text transform */
  .countdown-block--label-uppercase .countdown__text {
    text-transform: uppercase;
  }

  /* Unit visibility */
  .countdown-block--hide-days .countdown__item.Days { display: none; }
  .countdown-block--hide-hours .countdown__item.Hrs { display: none; }
  .countdown-block--hide-minutes .countdown__item.Min { display: none; }
  .countdown-block--hide-seconds .countdown__item.Sec { display: none; }
  .countdown-block--hide-labels .countdown__text { display: none; }
  .countdown-block--hide-separator .countdown__item + .countdown__item::before { display: none; }
{% endstylesheet %}

{%- liquid
  assign s = block.settings
  assign timer_type = s.timer_type

  if timer_type == 'fixed'
    assign minutes_padded = s.countdown_minutes | prepend: '00' | slice: -2, 2
    assign seconds_padded = s.countdown_seconds | prepend: '00' | slice: -2, 2
    assign countdown_datetime = s.year | append: '-' | append: s.countdown_month | append: '-' | append: s.countdown_days | append: 'T' | append: s.countdown_hours | append: ':' | append: minutes_padded | append: ':' | append: seconds_padded
    assign countdown_ts = countdown_datetime | date: '%s'
    assign now_ts = 'now' | date: '%s'
    assign timer_active = false
    if countdown_ts > now_ts
      assign timer_active = true
    endif
  endif

  assign evergreen_hours_ms = s.evergreen_hours | times: 3600000
  assign evergreen_minutes_ms = s.evergreen_minutes | times: 60000
  assign evergreen_ms = evergreen_hours_ms | plus: evergreen_minutes_ms

  assign gap_val = s.gap | append: 'px'

  assign hide_classes = ''
  unless s.show_days
    assign hide_classes = hide_classes | append: ' countdown-block--hide-days'
  endunless
  unless s.show_hours
    assign hide_classes = hide_classes | append: ' countdown-block--hide-hours'
  endunless
  unless s.show_minutes
    assign hide_classes = hide_classes | append: ' countdown-block--hide-minutes'
  endunless
  unless s.show_seconds
    assign hide_classes = hide_classes | append: ' countdown-block--hide-seconds'
  endunless
  unless s.show_labels
    assign hide_classes = hide_classes | append: ' countdown-block--hide-labels'
  endunless
  unless s.show_separator
    assign hide_classes = hide_classes | append: ' countdown-block--hide-separator'
  endunless
-%}

{%- capture inner_classes -%}countdown-block__inner countdown-block--style-{{ s.style }}{% if s.style == 'boxed' and s.box_border_style == 'square' %} countdown-block--box-square{% endif %}{% if s.label_text_style == 'uppercase' %} countdown-block--label-uppercase{% endif %}{%- endcapture -%}

{%- capture inner_style -%}gap: {{ gap_val }}; --countdown-gap: {{ gap_val }};{%- endcapture -%}

<div
  class="countdown-block{{ hide_classes }}"
  {{ block.shopify_attributes }}
>
  {%- if timer_type == 'fixed' -%}
    <countdown-timer>
      {%- if timer_active -%}
        <div
          class="{{ inner_classes }}"
          style="{{ inner_style }}"
          data-countdown="{{ countdown_datetime }}"
        >
          <div class="countdown__item Days">
            <span class="countdown__number">- -</span>
            <span class="countdown__text">{{ 'products.product.countdown_timer.days' | t }}</span>
          </div>
          <div class="countdown__item Hrs">
            <span class="countdown__number">- -</span>
            <span class="countdown__text">{{ 'products.product.countdown_timer.hours' | t }}</span>
          </div>
          <div class="countdown__item Min">
            <span class="countdown__number">- -</span>
            <span class="countdown__text">{{ 'products.product.countdown_timer.minutes' | t }}</span>
          </div>
          <div class="countdown__item Sec">
            <span class="countdown__number">- -</span>
            <span class="countdown__text">{{ 'products.product.countdown_timer.seconds' | t }}</span>
          </div>
        </div>
      {%- else -%}
        <div class="{{ inner_classes }}" style="{{ inner_style }}">
          <div class="countdown__item Days">
            <span class="countdown__number">00</span>
            <span class="countdown__text">{{ 'products.product.countdown_timer.days' | t }}</span>
          </div>
          <div class="countdown__item Hrs">
            <span class="countdown__number">00</span>
            <span class="countdown__text">{{ 'products.product.countdown_timer.hours' | t }}</span>
          </div>
          <div class="countdown__item Min">
            <span class="countdown__number">00</span>
            <span class="countdown__text">{{ 'products.product.countdown_timer.minutes' | t }}</span>
          </div>
          <div class="countdown__item Sec">
            <span class="countdown__number">00</span>
            <span class="countdown__text">{{ 'products.product.countdown_timer.seconds' | t }}</span>
          </div>
        </div>
      {%- endif -%}
    </countdown-timer>
  {%- else -%}
    <script src="{{ 'hooktheme-countdown-evergreen.js' | asset_url }}" defer></script>
    <countdown-timer-evergreen
      data-duration-ms="{{ evergreen_ms }}"
      data-block-id="{{ block.id }}"
      data-inner-classes="{{ inner_classes }}"
      data-inner-style="{{ inner_style }}"
      data-label-days="{{ 'products.product.countdown_timer.days' | t }}"
      data-label-hours="{{ 'products.product.countdown_timer.hours' | t }}"
      data-label-minutes="{{ 'products.product.countdown_timer.minutes' | t }}"
      data-label-seconds="{{ 'products.product.countdown_timer.seconds' | t }}"
    >
      <div class="countdown-block__inner"></div>
    </countdown-timer-evergreen>
  {%- endif -%}
</div>

