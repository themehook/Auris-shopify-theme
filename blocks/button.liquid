{% stylesheet %}
  .button-block {
    display: inline-flex;
    width: var(--btn-width, fit-content);
  }

  .button-block .button,
  .button-block .link {
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .button-block {
      width: var(--btn-width-mobile, var(--btn-width, fit-content));
    }
  }
{% endstylesheet %}

{%- liquid
  assign s = block.settings

  case s.width
    when 'custom'
      assign width_value = s.custom_width | append: '%'
    else
      assign width_value = 'fit-content'
  endcase

  case s.width_mobile
    when 'custom'
      assign width_mobile_value = s.custom_width_mobile | append: '%'
    else
      assign width_mobile_value = 'fit-content'
  endcase
-%}

<div
  class="button-block"
  style="
    --btn-width: {{ width_value }};
    --btn-width-mobile: {{ width_mobile_value }};
  "
  {{ block.shopify_attributes }}
>
  {%- if s.link != blank -%}
    <a
      href="{{ s.link }}"
      class="{{ s.style_class }}"
      {% if s.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
    >
      {{- s.label | escape -}}
    </a>
  {%- elsif s.label != blank -%}
    <span class="{{ s.style_class }}">{{ s.label | escape }}</span>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "Style",
      "options": [
        { "value": "button", "label": "Primary" },
        { "value": "button button--secondary", "label": "Secondary" },
        { "value": "link", "label": "Link" }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "Size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width (desktop)",
      "options": [
        { "value": "fit-content", "label": "Fit content" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "Width (mobile)",
      "options": [
        { "value": "fit-content", "label": "Fit content" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "Custom width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == 'custom' }}"
    }
  ],
  "presets": [
    {
      "name": "Button",
      "category": "Basic",
      "settings": {
        "link": "shopify://collections/all"
      }
    }
  ]
}
{% endschema %}
