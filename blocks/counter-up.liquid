{% stylesheet %}
  counter-up {
    display: block;
    text-align: var(--counter-up-text-align, center);
  }

  .counter-up__number {
    display: flex;
    align-items: baseline;
    justify-content: var(--counter-up-align, center);
  }

  .counter-up__prefix,
  .counter-up__suffix {
    flex-shrink: 0;
  }

  .counter-up__value {
    display: inline-flex;
    vertical-align: baseline;
  }

  .counter__group {
    display: inline-block;
    height: 1lh;
    overflow: clip;
    line-height: inherit;
  }

  .counter__track {
    display: flex;
    flex-direction: column;
    transition: transform var(--counter-duration, 2000ms) cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--counter-duration-offset, 0ms);
  }

  .counter__digit {
    line-height: inherit;
  }

  .counter__char {
    display: inline-block;
  }

  counter-up.is-playing .counter__track {
    transform: translateY(calc(-1lh * var(--counter-steps)));
  }

  .counter-up__heading {
    margin-top: 0.8rem;
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    counter-up {
      text-align: var(--counter-up-text-align-mobile, var(--counter-up-text-align, center));
    }

    .counter-up__number {
      justify-content: var(--counter-up-align-mobile, var(--counter-up-align, center));
    }
  }
{% endstylesheet %}

<script src="{{ 'hooktheme-counter-up.js' | asset_url }}" defer></script>

{%- liquid
  assign s = block.settings
  assign number = s.number | default: 0

  case s.alignment
    when 'flex-start'
      assign text_align = 'left'
    when 'flex-end'
      assign text_align = 'right'
    else
      assign text_align = 'center'
  endcase

  case s.alignment_mobile
    when 'flex-start'
      assign text_align_mobile = 'left'
    when 'flex-end'
      assign text_align_mobile = 'right'
    else
      assign text_align_mobile = 'center'
  endcase
-%}

<counter-up
  data-target="{{ number }}"
  data-duration="{{ s.duration }}"
  style="
    --counter-up-align: {{ s.alignment }};
    --counter-up-text-align: {{ text_align }};
    --counter-up-align-mobile: {{ s.alignment_mobile }};
    --counter-up-text-align-mobile: {{ text_align_mobile }};
  "
  {{ block.shopify_attributes }}
>
  <div class="counter-up__number {{ s.number_preset }}">
    {%- if s.prefix != blank -%}
      <span class="counter-up__prefix">{{ s.prefix }}</span>
    {%- endif -%}
    <span class="counter-up__value">0</span>
    {%- if s.suffix != blank -%}
      <span class="counter-up__suffix">{{ s.suffix }}</span>
    {%- endif -%}
  </div>
  {%- if s.heading != blank -%}
    <p class="counter-up__heading {{ s.heading_preset }}">{{ s.heading }}</p>
  {%- endif -%}
</counter-up>

{% schema %}
{
  "name": "Counter up",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Counter"
    },
    {
      "type": "number",
      "id": "number",
      "label": "Number",
      "default": 500
    },
    {
      "type": "text",
      "id": "prefix",
      "label": "Prefix",
      "info": "Text before the number (e.g., $)"
    },
    {
      "type": "text",
      "id": "suffix",
      "label": "Suffix",
      "default": "+",
      "info": "Text after the number (e.g., +, %)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Happy customers"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "alignment_mobile",
      "label": "Alignment on mobile",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "duration",
      "label": "Duration",
      "min": 1,
      "max": 10,
      "step": 0.5,
      "unit": "s",
      "default": 3
    },
    {
      "type": "header",
      "content": "Number style"
    },
    {
      "type": "select",
      "id": "number_preset",
      "label": "Preset",
      "options": [
        { "value": "rte", "label": "Default" },
        { "value": "h1", "label": "Heading 1" },
        { "value": "h2", "label": "Heading 2" },
        { "value": "h3", "label": "Heading 3" },
        { "value": "h4", "label": "Heading 4" },
        { "value": "h5", "label": "Heading 5" },
        { "value": "h6", "label": "Heading 6" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "Preset",
      "options": [
        { "value": "rte", "label": "Default" },
        { "value": "h1", "label": "Heading 1" },
        { "value": "h2", "label": "Heading 2" },
        { "value": "h3", "label": "Heading 3" },
        { "value": "h4", "label": "Heading 4" },
        { "value": "h5", "label": "Heading 5" },
        { "value": "h6", "label": "Heading 6" }
      ],
      "default": "h5"
    }
  ],
  "presets": [
    {
      "name": "Counter up",
      "category": "Basic"
    }
  ]
}
{% endschema %}
