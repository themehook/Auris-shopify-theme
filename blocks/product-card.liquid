{% stylesheet %}
  .product-card-block {
    min-width: 0;
    max-width: 100%;
    width: var(--pc-width, 100%);
    padding-top: var(--pc-pad-top, 0);
    padding-bottom: var(--pc-pad-bottom, 0);
    padding-left: var(--pc-pad-left, 0);
    padding-right: var(--pc-pad-right, 0);
  }

  @media screen and (max-width: 749px) {
    .product-card-block {
      width: var(--pc-width-mobile, var(--pc-width, 100%));
      padding-top: calc(var(--pc-pad-top, 0) * var(--pc-mobile-scale, 0.8));
      padding-bottom: calc(var(--pc-pad-bottom, 0) * var(--pc-mobile-scale, 0.8));
      padding-left: calc(var(--pc-pad-left, 0) * var(--pc-mobile-scale, 0.8));
      padding-right: calc(var(--pc-pad-right, 0) * var(--pc-mobile-scale, 0.8));
    }
  }

  .product-card-block .product__card {
    border-radius: var(--pc-corner-radius, 0);
  }

  .product-card-block .product__card__thumbnail {
    border-radius: var(--pc-image-radius, 0);
    overflow: hidden;
  }

  .product-card-block .product-card-placeholder > div:first-child {
    border-radius: var(--pc-image-radius, 0);
  }

  .product-card-block--bordered .product__card {
    border: var(--pc-border-thickness, 1px) solid rgba(var(--color-foreground), var(--pc-border-opacity, 0.12));
  }
{% endstylesheet %}

{%- liquid
  assign s = block.settings

  case s.width
    when 'fill'
      assign width_value = '100%'
    when 'custom'
      assign width_value = s.custom_width | append: '%'
    else
      assign width_value = 'fit-content'
  endcase

  case s.width_mobile
    when 'fill'
      assign width_mobile_value = '100%'
    when 'custom'
      assign width_mobile_value = s.custom_width_mobile | append: '%'
    else
      assign width_mobile_value = 'fit-content'
  endcase

  if s.width == 'custom'
    assign _custom_px = settings.container_lg_width | times: s.custom_width | divided_by: 100 | round
    assign pc_sizes = '(min-width: ' | append: settings.container_lg_width | append: 'px) ' | append: _custom_px | append: 'px, calc((100vw - 40px) * ' | append: s.custom_width | append: ' / 100)'
  elsif s.width == 'fill'
    assign pc_sizes = '(min-width: ' | append: settings.container_lg_width | append: 'px) ' | append: settings.container_lg_width | append: 'px, calc(100vw - 40px)'
  else
    assign pc_sizes = '(min-width: 990px) 400px, calc(100vw - 40px)'
  endif
-%}

<div
  class="product-card-block{% if s.border_style == 'solid' %} product-card-block--bordered{% endif %}"
  style="
    --pc-width: {{ width_value }};
    --pc-width-mobile: {{ width_mobile_value }};
    --pc-corner-radius: {{ s.corner_radius }}px;
    --pc-image-radius: {{ s.image_corner_radius }}px;
    --pc-border-thickness: {{ s.border_thickness }}px;
    --pc-border-opacity: {{ s.border_opacity | divided_by: 100.0 }};
    --pc-pad-top: {{ s.padding_top }}px;
    --pc-pad-bottom: {{ s.padding_bottom }}px;
    --pc-pad-left: {{ s.padding_left }}px;
    --pc-pad-right: {{ s.padding_right }}px;
    --pc-mobile-scale: {{ s.mobile_scale | divided_by: 100.0 }};
  "
  {{ block.shopify_attributes }}
>
  {%- if s.product != blank -%}
    {% render 'product-card',
      product_card_product: s.product,
      section_id: block.id,
      media_size: s.image_ratio,
      sizes: pc_sizes,
      show_secondary_image: s.show_secondary_image,
      show_vendor: s.show_vendor,
      show_badge: s.show_badges,
      show_cart_button: s.show_cart_button,
      show_preorder_button: s.show_preorder_button,
      show_quick_view: s.show_quick_view_button,
      show_quick_compare: s.show_compare_view_button,
      show_wishlist: s.show_wishlist_button,
      show_countdown: s.show_countdown,
      show_title: s.show_title,
      show_price: s.show_price,
      show_rating: s.show_product_rating,
      card_style: s.card_style,
      color_swatches: s.color_swatches,
      color_scheme: s.product_card_color_scheme,
      spacing: s.product_card_spacing,
      cart_button_type: s.cart_button_type,
      action_buttons_position: s.action_buttons_position,
      action_buttons_style: s.action_button_style,
      show_always: s.show_always,
      low_stock_value: s.low_stock_value,
      minimum_amount_value: s.minimum_amount_value,
      show_inventory_quantity: s.show_inventory_quantity,
      show_inventory_status: s.show_inventory_status,
      in_stock_color: s.in_stock,
      out_of_stock_color: s.out_of_stock,
      low_stock_color: s.low_stock,
      continue_selling_color: s.continue_selling
    %}
  {%- else -%}
    {% render 'product-card-placeholder',
      image_ratio: s.image_ratio,
      index: 1
    %}
  {%- endif -%}
</div>

{% schema %}
