{% stylesheet %}
  accordion-group {
    display: block;
    min-width: 0;
    max-width: 100%;
    width: var(--accordion-width, 100%);
  }

  .accordion-block {
    width: 100%;
    padding-top: var(--accordion-pad-top, 0);
    padding-bottom: var(--accordion-pad-bottom, 0);
    padding-left: var(--accordion-pad-left, 0);
    padding-right: var(--accordion-pad-right, 0);
  }

  /* Heading preset — parent class controls child heading appearance */
  .accordion-block--heading-h1 .accordion-row__heading { font-size: calc(var(--font-heading-size) * 2.8rem); }
  .accordion-block--heading-h2 .accordion-row__heading { font-size: calc(var(--font-heading-size) * 2.2rem); }
  .accordion-block--heading-h3 .accordion-row__heading { font-size: calc(var(--font-heading-size) * 2rem); }
  .accordion-block--heading-h4 .accordion-row__heading { font-size: calc(var(--font-heading-size) * 1.6rem); }
  .accordion-block--heading-h5 .accordion-row__heading { font-size: calc(var(--font-heading-size) * 1.3rem); }
  .accordion-block--heading-h6 .accordion-row__heading { font-size: calc(var(--font-heading-size) * 1.1rem); }
  .accordion-block--heading-p .accordion-row__heading {
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight);
    font-size: 1.4rem;
  }

  /* Border — parent class controls row borders */
  .accordion-block--bordered .accordion-row {
    border-bottom: var(--accordion-border-width, 1px) solid rgba(var(--color-foreground), var(--accordion-border-opacity, 0.12));
  }

  .accordion-block--bordered .accordion-row:first-child {
    border-top: var(--accordion-border-width, 1px) solid rgba(var(--color-foreground), var(--accordion-border-opacity, 0.12));
  }

  /* Card style */
  .accordion-block--card {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .accordion-block--card[class*="color-"] {
    background-color: transparent;
  }

  .accordion-block--card .accordion-row {
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    border-radius: var(--accordion-radius, 0);
  }

  .accordion-block--card .accordion-row__header {
    padding-top: var(--row-pad-top, 16px);
    padding-bottom: var(--row-pad-bottom, 16px);
    padding-left: calc(var(--row-pad-left, 0px) + 20px);
    padding-right: calc(var(--row-pad-right, 0px) + 20px);
  }

  .accordion-block--card .accordion-row__content {
    padding-top: 0;
    padding-bottom: var(--row-pad-bottom, 16px);
    padding-left: calc(var(--row-pad-left, 0px) + 20px);
    padding-right: calc(var(--row-pad-right, 0px) + 20px);
  }

  /* Card + bordered */
  .accordion-block--card.accordion-block--bordered .accordion-row {
    border: var(--accordion-border-width, 1px) solid rgba(var(--color-foreground), var(--accordion-border-opacity, 0.12));
  }

  @media screen and (max-width: 749px) {
    accordion-group {
      width: var(--accordion-width-mobile, var(--accordion-width, 100%));
    }

    .accordion-block {
      padding-top: calc(var(--accordion-pad-top, 0) * var(--accordion-mobile-scale, 0.8));
      padding-bottom: calc(var(--accordion-pad-bottom, 0) * var(--accordion-mobile-scale, 0.8));
      padding-left: calc(var(--accordion-pad-left, 0) * var(--accordion-mobile-scale, 0.8));
      padding-right: calc(var(--accordion-pad-right, 0) * var(--accordion-mobile-scale, 0.8));
    }

    .accordion-row__header {
      padding-top: calc(var(--row-pad-top, 16px) * var(--row-mobile-scale, 0.8));
      padding-bottom: calc(var(--row-pad-bottom, 16px) * var(--row-mobile-scale, 0.8));
      padding-left: calc(var(--row-pad-left, 0px) * var(--row-mobile-scale, 0.8));
      padding-right: calc(var(--row-pad-right, 0px) * var(--row-mobile-scale, 0.8));
    }

    .accordion-row__content {
      padding-bottom: calc(var(--row-pad-bottom, 16px) * var(--row-mobile-scale, 0.8));
      padding-left: calc(var(--row-pad-left, 0px) * var(--row-mobile-scale, 0.8));
      padding-right: calc(var(--row-pad-right, 0px) * var(--row-mobile-scale, 0.8));
    }

    .accordion-block--card .accordion-row__header {
      padding-left: calc(calc(var(--row-pad-left, 0px) * var(--row-mobile-scale, 0.8)) + 20px);
      padding-right: calc(calc(var(--row-pad-right, 0px) * var(--row-mobile-scale, 0.8)) + 20px);
    }

    .accordion-block--card .accordion-row__content {
      padding-left: calc(calc(var(--row-pad-left, 0px) * var(--row-mobile-scale, 0.8)) + 20px);
      padding-right: calc(calc(var(--row-pad-right, 0px) * var(--row-mobile-scale, 0.8)) + 20px);
    }
  }
{% endstylesheet %}

{%- liquid
  assign s = block.settings
  assign icon = s.icon

  case s.width
    when 'fill'
      assign width_value = '100%'
    when 'custom'
      assign width_value = s.custom_width | append: '%'
    else
      assign width_value = 'fit-content'
  endcase

  case s.width_mobile
    when 'fill'
      assign width_mobile_value = '100%'
    when 'custom'
      assign width_mobile_value = s.custom_width_mobile | append: '%'
    else
      assign width_mobile_value = 'fit-content'
  endcase
-%}

{%- capture children -%}
  {% content_for 'blocks' %}
{%- endcapture -%}

<script src="{{ 'hooktheme-accordion-block.js' | asset_url }}" defer="defer"></script>

<accordion-group
  data-open-behavior="{{ s.open_behavior }}"
  style="
    --accordion-width: {{ width_value }};
    --accordion-width-mobile: {{ width_mobile_value }};
  "
>
  <div
    class="accordion-block accordion-block--icon-{{ icon }} accordion-block--icon-{{ s.icon_style }} accordion-block--heading-{{ s.heading_tag }} accordion-block--{{ s.style }}{% if s.border_style == 'solid' %} accordion-block--bordered{% endif %}{% if s.style == 'card' %} color-{{ s.color_scheme }}{% endif %}"
    style="
      --accordion-radius: {{ s.border_radius | divided_by: 10.0 }}rem;
      --accordion-border-width: {{ s.border_width }}px;
      --accordion-border-opacity: {{ s.border_opacity | divided_by: 100.0 }};
      --accordion-pad-top: {{ s.padding_top }}px;
      --accordion-pad-bottom: {{ s.padding_bottom }}px;
      --accordion-pad-left: {{ s.padding_left }}px;
      --accordion-pad-right: {{ s.padding_right }}px;
      --accordion-mobile-scale: {{ s.mobile_scale | divided_by: 100.0 }};
      --row-pad-top: {{ s.row_padding_top }}px;
      --row-pad-bottom: {{ s.row_padding_bottom }}px;
      --row-pad-left: {{ s.row_padding_left }}px;
      --row-pad-right: {{ s.row_padding_right }}px;
      --row-mobile-scale: {{ s.row_mobile_scale | divided_by: 100.0 }};
    "
    {{ block.shopify_attributes }}
  >
    {{ children }}
  </div>
</accordion-group>

{% schema %}
